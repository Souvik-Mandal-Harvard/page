le_right_elbow\",\n    \"angle_right_knee\",\n    \"angle_right_hip\",\n]\n\n# --- Confidence gate (optional): keep frames where each angle's confidence is in this set\nallowed_conf_levels = {\"good\"}   # e.g., {\"good\"}, or {\"good\",\"low\"}\n\n# --- If your CSV contains multiple videos, you can focus on one (or leave None)\nselected_video = None            # e.g., \"myvideo.mp4\" or None to keep all\n\n# --- Angle-thresholded mode: define per-angle conditions\n# Supported operators: \">\", \">=\", \"<\", \"<=\", \"==\", \"!=\"\n# threshold_logic: \"all\" (all conditions must hold) or \"any\" (at least one)\nangle_thresholds = {\n    # \"angle_left_knee\": (\">=\", 140),\n    # \"angle_right_knee\": (\">=\", 140),\n}\nthreshold_logic = \"all\"          # \"all\" | \"any\"\n\n# --- Running-average mode: rolling window size (frames) and centering\nrunning_window = 11              # odd number recommended (e.g., 11 means ±5 frames)\nrunning_center = True            # center the window\nrunning_min_periods = 1          # minimum frames to compute a mean\n","key":"An8HRUXzLO"},{"type":"outputs","id":"YKVgiBwqpncqFcjbEvK-R","children":[],"key":"IF9Siqt2Dh"}],"key":"bxemdlygfC"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":3,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Build the working angle table based on your selection mode","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"R1LxIVBMU9"}],"identifier":"build-the-working-angle-table-based-on-your-selection-mode","label":"Build the working angle table based on your selection mode","html_id":"build-the-working-angle-table-based-on-your-selection-mode","implicit":true,"key":"IeTZitmOdD"},{"type":"list","ordered":false,"spread":false,"position":{"start":{"line":3,"column":1},"end":{"line":8,"column":1}},"children":[{"type":"listItem","spread":true,"position":{"start":{"line":3,"column":1},"end":{"li