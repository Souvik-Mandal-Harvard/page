ue":"If we skip every other frame, we effectively output half the frames.","position":{"start":{"line":34,"column":1},"end":{"line":34,"column":1}},"key":"I9Pp0qHBix"},{"type":"break","position":{"start":{"line":34,"column":1},"end":{"line":34,"column":1}},"key":"HRLqbqBT1X"},{"type":"text","value":"To keep the video length the same, we also ","position":{"start":{"line":34,"column":1},"end":{"line":34,"column":1}},"key":"bwTlPf4QlF"},{"type":"strong","position":{"start":{"line":34,"column":1},"end":{"line":34,"column":1}},"children":[{"type":"text","value":"halve the FPS","position":{"start":{"line":34,"column":1},"end":{"line":34,"column":1}},"key":"gOkzPOD6vD"}],"key":"iOjY6Jprb9"},{"type":"text","value":" when writing the output video.","position":{"start":{"line":34,"column":1},"end":{"line":34,"column":1}},"key":"CHoU3XHfQ1"}],"key":"yWs4qaMboS"},{"type":"paragraph","position":{"start":{"line":37,"column":1},"end":{"line":37,"column":1}},"children":[{"type":"text","value":"Example:","position":{"start":{"line":37,"column":1},"end":{"line":37,"column":1}},"key":"CyhjUjcTMy"}],"key":"Nst0VUNYqe"},{"type":"list","ordered":false,"spread":false,"position":{"start":{"line":39,"column":1},"end":{"line":41,"column":1}},"children":[{"type":"listItem","spread":true,"position":{"start":{"line":39,"column":1},"end":{"line":39,"column":1}},"children":[{"type":"paragraph","children":[{"type":"text","value":"Input video: 120 FPS, 600 frames → 20 seconds","position":{"start":{"line":39,"column":1},"end":{"line":39,"column":1}},"key":"aTXFkrFPDb"}],"key":"h7XpuffPAo"}],"key":"dRYG0VYbtv"},{"type":"listItem","spread":true,"position":{"start":{"line":40,"column":1},"end":{"line":41,"column":1}},"children":[{"type":"paragraph","children":[{"type":"text","value":"Output video: 60 FPS, 300 frames → still 20 seconds","position":{"start":{"line":40,"column":1},"end":{"line":40,"column":1}},"key":"NFGZqAf43v"}],"key":"pPA0lOB2uw"}],"key":"T5fQ46fMjx"}],"key":"J3KxNecnk4"},{"type":"paragraph","position":{"start":{"line":42,"column":1},"end":{"line":42,"column":1}},"children":[{"type":"text","value":"This preserves video timing.","position":{"start":{"line":42,"column":1},"end":{"line":42,"column":1}},"key":"yXD4Y8kVHz"}],"key":"xbvardaNXi"},{"type":"thematicBreak","position":{"start":{"line":44,"column":1},"end":{"line":44,"column":1}},"key":"pYtp1II7mx"}],"key":"fDn24tIdzb"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":3,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Make the Python Function","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"mBCZ9AqQuj"}],"identifier":"make-the-python-function","label":"Make the Python Function","html_id":"make-the-python-function","implicit":true,"key":"cvepuA0Fa2"}],"key":"TeHWq5W9B2"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"import os\nimport cv2\nfrom tqdm import tqdm\n\ndef reduce_frames_in_directory(directory_path: str):\n    # Supported video extensions\n    VIDEO_EXTENSIONS = ('.mp4', '.mov', '.avi', '.mkv', '.flv')\n\n    # List all video files in the directory\n    files = [f for f in os.listdir(directory_path) if f.lower().endswith(VIDEO_EXTENSIONS)]\n\n    if not files:\n        print(\"No video files found in the directory.\")\n        return\n\n    for file in files:\n        input_path = os.path.join(directory_path, file)\n        basename, ext = os.path.splitext(file)\n\n        output_filename = f\"{basename}_FrameReduced{ext}\"\n        output_path = os.path.join(directory_path, output_filename)\n\n        print(f\"\\nProcessing: {file}\")\n        \n        cap = cv2.VideoCapture(input_path)\n        if not cap.isOpened():\n            print(f\"Could not open {file}. Skipping.\")\n            continue\n        \n        # Read input video properties\n        input_fps = cap.get(cv2.CAP_PROP_FPS)\n        width  = int(cap.get(cv2.CAP_PROP_FRAME_WIDTH))\n        height = int(cap.get(cv2.CAP_PROP_FRAME_HEIGHT))\n\n        # New FPS = half the original\n        output_fps = input_fps / 2\n\n        # Video writer\n        fourcc = cv2.VideoWriter_fourcc(*\"mp4v\")\n        out = cv2.VideoWriter(output_path, fourcc, output_fps, (width, height))\n\n        frame_count = int(cap.get(cv2.CAP_PROP_FRAME_COUNT))\n        \n        # Loop through frames\n        for i in tqdm(range(frame_count), desc=f\"Writing {output_filename}\"):\n            ret, frame = cap.read()\n            if not ret:\n                break\n            \n            # Skip every other frame → keep even-numbered frames only\n            if i % 2 == 0:\n                out.write(frame)\n\n        cap.release()\n        out.release()\n\n        print(f\"Saved: {output_filename}\")\n\n","key":"sPB39bORjP"},{"type":"outputs","id":"-3W0Lqz5udOmfLqSgKEhd","children":[],"key":"IEVOJgd92a"}],"key":"vN9A3evVKF"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":3,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"RUN THE FUNCTION BELOW","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"ixbv9KZjNf"}],"identifier":"run-the-function-below","label":"RUN THE FUNCTION BELOW","html_id":"run-the-function-below","implicit":true,"key":"uT2THO6176"}],"key":"BpOvUD7sjj"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"# Example:\ndirectory_path = \"path/to/yours/videos\"\nreduce_frames_in_directory(directory_path)","key":"iFWMZEXi06"},{"type":"outputs","id":"J5choGTpctFWs2DU9URfa","children":[],"key":"Gf45FSeXvx"}],"key":"ExCDyD5lC6"}],"key":"kQUlRqdfFk"},"references":{"cite":{"order":[],"data":{}}},"footer":{"navigation":{"prev":{"title":"NB01: Loading Video Data and Doing Useful Work","short_title":"Notebook 01 · Getting Started with Video Data","url":"/ls100-module-01a-video-data-content-01-00-getting-","group":"Modules"},"next":{"title":"Video Chunker by Frame Count (OpenCV)","short_title":"Notebook 03 · Video Chunker","url":"/ls100-module-01a-video-data-content-03-stage-01-vi","group":"Modules"}}},"domain":"http://localhost:3000"}