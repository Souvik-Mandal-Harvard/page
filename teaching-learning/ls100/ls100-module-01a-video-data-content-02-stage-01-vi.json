B4"},{"type":"paragraph","position":{"start":{"line":34,"column":1},"end":{"line":35,"column":1}},"children":[{"type":"text","value":"If we skip every other frame, we effectively output half the frames.","position":{"start":{"line":34,"column":1},"end":{"line":34,"column":1}},"key":"vEfvjBhBFL"},{"type":"break","position":{"start":{"line":34,"column":1},"end":{"line":34,"column":1}},"key":"bJnEjVm9ZS"},{"type":"text","value":"To keep the video length the same, we also ","position":{"start":{"line":34,"column":1},"end":{"line":34,"column":1}},"key":"J9rJslFHky"},{"type":"strong","position":{"start":{"line":34,"column":1},"end":{"line":34,"column":1}},"children":[{"type":"text","value":"halve the FPS","position":{"start":{"line":34,"column":1},"end":{"line":34,"column":1}},"key":"BjJqiqH57q"}],"key":"ZwMO7jwgpx"},{"type":"text","value":" when writing the output video.","position":{"start":{"line":34,"column":1},"end":{"line":34,"column":1}},"key":"LWpb0UauZn"}],"key":"ugj9ZLap2a"},{"type":"paragraph","position":{"start":{"line":37,"column":1},"end":{"line":37,"column":1}},"children":[{"type":"text","value":"Example:","position":{"start":{"line":37,"column":1},"end":{"line":37,"column":1}},"key":"dIjaVI4hKf"}],"key":"elzal9J8Sn"},{"type":"list","ordered":false,"spread":false,"position":{"start":{"line":39,"column":1},"end":{"line":41,"column":1}},"children":[{"type":"listItem","spread":true,"position":{"start":{"line":39,"column":1},"end":{"line":39,"column":1}},"children":[{"type":"paragraph","children":[{"type":"text","value":"Input video: 120 FPS, 600 frames → 20 seconds","position":{"start":{"line":39,"column":1},"end":{"line":39,"column":1}},"key":"De12Sohzn9"}],"key":"MjLg4BpBNB"}],"key":"fPX3lUWl25"},{"type":"listItem","spread":true,"position":{"start":{"line":40,"column":1},"end":{"line":41,"column":1}},"children":[{"type":"paragraph","children":[{"type":"text","value":"Output video: 60 FPS, 300 frames → still 20 seconds","position":{"start":{"line":40,"column":1},"end":{"line":40,"column":1}},"key":"McCPuqQCcC"}],"key":"tx2lONP2AB"}],"key":"AswGLeBblc"}],"key":"PgplJNoNiX"},{"type":"paragraph","position":{"start":{"line":42,"column":1},"end":{"line":42,"column":1}},"children":[{"type":"text","value":"This preserves video timing.","position":{"start":{"line":42,"column":1},"end":{"line":42,"column":1}},"key":"Fks7jvhFdt"}],"key":"Fe0SQXwnzd"},{"type":"thematicBreak","position":{"start":{"line":44,"column":1},"end":{"line":44,"column":1}},"key":"D6qmuN2IzK"}],"key":"fcrvFbHVnW"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":3,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Make the Python Function","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"pHIIb9B25n"}],"identifier":"make-the-python-function","label":"Make the Python Function","html_id":"make-the-python-function","implicit":true,"key":"geqksdg6Gg"}],"key":"F3DPMUkdXR"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"import os\nimport cv2\nfrom tqdm import tqdm\n\ndef reduce_frames_in_directory(directory_path: str):\n    # Supported video extensions\n    VIDEO_EXTENSIONS = ('.mp4', '.mov', '.avi', '.mkv', '.flv')\n\n    # List all video files in the directory\n    files = [f for f in os.listdir(directory_path) if f.lower().endswith(VIDEO_EXTENSIONS)]\n\n    if not files:\n        print(\"No video files found in the directory.\")\n        return\n\n    for file in files:\n        input_path = os.path.join(directory_path, file)\n        basename, ext = os.path.splitext(file)\n\n        output_filename = f\"{basename}_FrameReduced{ext}\"\n        output_path = os.path.join(directory_path, output_filename)\n\n        print(f\"\\nProcessing: {file}\")\n        \n        cap = cv2.VideoCapture(input_path)\n        if not cap.isOpened():\n            print(f\"Could not open {file}. Skipping.\")\n            continue\n        \n        # Read input video properties\n        input_fps = cap.get(cv2.CAP_PROP_FPS)\n        width  = int(cap.get(cv2.CAP_PROP_FRAME_WIDTH))\n        height = int(cap.get(cv2.CAP_PROP_FRAME_HEIGHT))\n\n        # New FPS = half the original\n        output_fps = input_fps / 2\n\n        # Video writer\n        fourcc = cv2.VideoWriter_fourcc(*\"mp4v\")\n        out = cv2.VideoWriter(output_path, fourcc, output_fps, (width, height))\n\n        frame_count = int(cap.get(cv2.CAP_PROP_FRAME_COUNT))\n        \n        # Loop through frames\n        for i in tqdm(range(frame_count), desc=f\"Writing {output_filename}\"):\n            ret, frame = cap.read()\n            if not ret:\n                break\n            \n            # Skip every other frame → keep even-numbered frames only\n            if i % 2 == 0:\n                out.write(frame)\n\n        cap.release()\n        out.release()\n\n        print(f\"Saved: {output_filename}\")\n\n","key":"omqub2MvA2"},{"type":"outputs","id":"DHEQI7XvVFjX4RaRaq2iT","children":[],"key":"lnWFSxt6xI"}],"key":"B5Qb2RNzG5"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":3,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"RUN THE FUNCTION BELOW","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"iyndxC3fOv"}],"identifier":"run-the-function-below","label":"RUN THE FUNCTION BELOW","html_id":"run-the-function-below","implicit":true,"key":"nEqSniHLuV"}],"key":"rNFHfKF8Pj"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"# Example:\ndirectory_path = \"path/to/yours/videos\"\nreduce_frames_in_directory(directory_path)","key":"Lro4BFkRTZ"},{"type":"outputs","id":"2Gd5e_qJeTvtdQhEUQ0af","children":[],"key":"mGEDxFqjrv"}],"key":"NPN6DAhgVE"}],"key":"ZPeXpr3CmK"},"references":{"cite":{"order":[],"data":{}}},"footer":{"navigation":{"prev":{"title":"NB01: Loading Video Data and Doing Useful Work","short_title":"Notebook 01 · Getting Started with Video Data","url":"/ls100-module-01a-video-data-content-01-00-getting-","group":"Modules"},"next":{"title":"NB03: Video Chunker by Frame Count (OpenCV)","short_title":"Notebook 03 · Video Chunker","url":"/ls100-module-01a-video-data-content-03-stage-01-vi","group":"Modules"}}},"domain":"http://localhost:3000"}