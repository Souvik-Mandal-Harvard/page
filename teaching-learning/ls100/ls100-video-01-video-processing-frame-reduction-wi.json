","position":{"start":{"line":26,"column":1},"end":{"line":26,"column":1}},"key":"TEW2Tg1mJT"}],"identifier":"output-format","label":"Output Format","html_id":"output-format","implicit":true,"key":"DxF9nBOaDx"},{"type":"paragraph","position":{"start":{"line":27,"column":1},"end":{"line":29,"column":1}},"children":[{"type":"text","value":"For an input file like: ","position":{"start":{"line":27,"column":1},"end":{"line":27,"column":1}},"key":"I728yj2XMd"},{"type":"inlineCode","value":"walking.mp4","position":{"start":{"line":27,"column":1},"end":{"line":27,"column":1}},"key":"iGQuF7TcjP"},{"type":"text","value":"\nThe output file will be: ","position":{"start":{"line":27,"column":1},"end":{"line":27,"column":1}},"key":"hitXITFu9w"},{"type":"inlineCode","value":"walking_FrameReduced.mp4","position":{"start":{"line":27,"column":1},"end":{"line":27,"column":1}},"key":"bEkU0Q1lnQ"},{"type":"text","value":"\nin the ","position":{"start":{"line":27,"column":1},"end":{"line":27,"column":1}},"key":"rXM8LrfZQn"},{"type":"strong","position":{"start":{"line":27,"column":1},"end":{"line":27,"column":1}},"children":[{"type":"text","value":"same directory","position":{"start":{"line":27,"column":1},"end":{"line":27,"column":1}},"key":"zbpskKwKve"}],"key":"wGkqi5XCuF"},{"type":"text","value":", and the video will keep its original duration even though half the frames are removed.","position":{"start":{"line":27,"column":1},"end":{"line":27,"column":1}},"key":"tF2yRtsNDQ"}],"key":"wTmNFN6emv"},{"type":"thematicBreak","position":{"start":{"line":31,"column":1},"end":{"line":31,"column":1}},"key":"zhj23og5jq"},{"type":"heading","depth":1,"position":{"start":{"line":33,"column":1},"end":{"line":33,"column":1}},"children":[{"type":"text","value":"How We Keep the Original Duration","position":{"start":{"line":33,"column":1},"end":{"line":33,"column":1}},"key":"Yh5IP1s3ph"}],"identifier":"how-we-keep-the-original-duration","label":"How We Keep the Original Duration","html_id":"how-we-keep-the-original-duration","implicit":true,"key":"bMYexIGdeK"},{"type":"paragraph","position":{"start":{"line":35,"column":1},"end":{"line":36,"column":1}},"children":[{"type":"text","value":"If we skip every other frame, we effectively output half the frames.","position":{"start":{"line":35,"column":1},"end":{"line":35,"column":1}},"key":"lymlreVwXe"},{"type":"break","position":{"start":{"line":35,"column":1},"end":{"line":35,"column":1}},"key":"axmOSzS2w0"},{"type":"text","value":"To keep the video length the same, we also ","position":{"start":{"line":35,"column":1},"end":{"line":35,"column":1}},"key":"snmhXfppL7"},{"type":"strong","position":{"start":{"line":35,"column":1},"end":{"line":35,"column":1}},"children":[{"type":"text","value":"halve the FPS","position":{"start":{"line":35,"column":1},"end":{"line":35,"column":1}},"key":"xARcRemvuI"}],"key":"iTcMAkhfot"},{"type":"text","value":" when writing the output video.","position":{"start":{"line":35,"column":1},"end":{"line":35,"column":1}},"key":"MHlwHzjHoW"}],"key":"uKNSU9xTh1"},{"type":"paragraph","position":{"start":{"line":38,"column":1},"end":{"line":38,"column":1}},"children":[{"type":"text","value":"Example:","position":{"start":{"line":38,"column":1},"end":{"line":38,"column":1}},"key":"vJnhyCPSWx"}],"key":"wmA6y1jS1Q"},{"type":"list","ordered":false,"spread":false,"position":{"start":{"line":40,"column":1},"end":{"line":42,"column":1}},"children":[{"type":"listItem","spread":true,"position":{"start":{"line":40,"column":1},"end":{"line":40,"column":1}},"children":[{"type":"paragraph","children":[{"type":"text","value":"Input video: 120 FPS, 600 frames → 20 seconds","position":{"start":{"line":40,"column":1},"end":{"line":40,"column":1}},"key":"d5JlvUmSxc"}],"key":"URQ8neZ40V"}],"key":"eJcoasQQTV"},{"type":"listItem","spread":true,"position":{"start":{"line":41,"column":1},"end":{"line":42,"column":1}},"children":[{"type":"paragraph","children":[{"type":"text","value":"Output video: 60 FPS, 300 frames → still 20 seconds","position":{"start":{"line":41,"column":1},"end":{"line":41,"column":1}},"key":"pveFOSqk6V"}],"key":"Ak5JcMnVR8"}],"key":"qEx0hkkvOB"}],"key":"vIb0wcgCId"},{"type":"paragraph","position":{"start":{"line":43,"column":1},"end":{"line":43,"column":1}},"children":[{"type":"text","value":"This preserves video timing.","position":{"start":{"line":43,"column":1},"end":{"line":43,"column":1}},"key":"DOTv8kx5nc"}],"key":"yZfO5vKYUG"},{"type":"thematicBreak","position":{"start":{"line":45,"column":1},"end":{"line":45,"column":1}},"key":"suKiNhy1BY"}],"key":"FCCbNXRibD"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Make the Python Function","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"dEI0A40ZIu"}],"identifier":"make-the-python-function","label":"Make the Python Function","html_id":"make-the-python-function","implicit":true,"key":"Gx1SF8buU4"}],"key":"H3Wl7dTn5p"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"import os\nimport cv2\nfrom tqdm import tqdm\n\ndef reduce_frames_in_directory(directory_path: str):\n    # Supported video extensions\n    VIDEO_EXTENSIONS = ('.mp4', '.mov', '.avi', '.mkv', '.flv')\n\n    # List all video files in the directory\n    files = [f for f in os.listdir(directory_path) if f.lower().endswith(VIDEO_EXTENSIONS)]\n\n    if not files:\n        print(\"No video files found in the directory.\")\n        return\n\n    for file in files:\n        input_path = os.path.join(directory_path, file)\n        basename, ext = os.path.splitext(file)\n\n        output_filename = f\"{basename}_FrameReduced{ext}\"\n        output_path = os.path.join(directory_path, output_filename)\n\n        print(f\"\\nProcessing: {file}\")\n        \n        cap = cv2.VideoCapture(input_path)\n        if not cap.isOpened():\n            print(f\"Could not open {file}. Skipping.\")\n            continue\n        \n        # Read input video properties\n        input_fps = cap.get(cv2.CAP_PROP_FPS)\n        width  = int(cap.get(cv2.CAP_PROP_FRAME_WIDTH))\n        height = int(cap.get(cv2.CAP_PROP_FRAME_HEIGHT))\n\n        # New FPS = half the original\n        output_fps = input_fps / 2\n\n        # Video writer\n        fourcc = cv2.VideoWriter_fourcc(*\"mp4v\")\n        out = cv2.VideoWriter(output_path, fourcc, output_fps, (width, height))\n\n        frame_count = int(cap.get(cv2.CAP_PROP_FRAME_COUNT))\n        \n        # Loop through frames\n        for i in tqdm(range(frame_count), desc=f\"Writing {output_filename}\"):\n            ret, frame = cap.read()\n            if not ret:\n                break\n            \n            # Skip every other frame → keep even-numbered frames only\n            if i % 2 == 0:\n                out.write(frame)\n\n        cap.release()\n        out.release()\n\n        print(f\"Saved: {output_filename}\")\n\n","key":"C63gs92vFm"},{"type":"outputs","id":"J8GsTo4_KZHD3NQw_y6gk","children":[],"key":"bJmxco0K4D"}],"key":"KAm8axo9yv"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"RUN THE FUNCTION BELOW","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"k4BXrNhXZM"}],"identifier":"run-the-function-below","label":"RUN THE FUNCTION BELOW","html_id":"run-the-function-below","implicit":true,"key":"eWVqfrxy3H"}],"key":"MDBFQpyNxr"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"# Example:\ndirectory_path = \"path/to/yours/videos\"\nreduce_frames_in_directory(directory_path)","key":"HycxmwIxVZ"},{"type":"outputs","id":"ZNKqAP10HV0AiSx8yqUkQ","children":[],"key":"x4QAgvyMig"}],"key":"VPkJ4kqo2b"}],"key":"ohhFqqPaFV"},"references":{"cite":{"order":[],"data":{}}},"footer":{"navigation":{"prev":{"title":"Loading Data and Doing Useful Work — Video","url":"/ls100-video-00-getting-started","group":"Modules"},"next":{"title":"Video Chunker by Frame Count (OpenCV)","url":"/ls100-video-01-video-processing-video-chunker-by-f","group":"Modules"}}},"domain":"http://localhost:3000"}