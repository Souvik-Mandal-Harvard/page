-the-original-duration","implicit":true,"key":"mTVPQmAo33"},{"type":"paragraph","position":{"start":{"line":35,"column":1},"end":{"line":36,"column":1}},"children":[{"type":"text","value":"If we skip every other frame, we effectively output half the frames.","position":{"start":{"line":35,"column":1},"end":{"line":35,"column":1}},"key":"sHDNE03yFV"},{"type":"break","position":{"start":{"line":35,"column":1},"end":{"line":35,"column":1}},"key":"CRs3FGRYaL"},{"type":"text","value":"To keep the video length the same, we also ","position":{"start":{"line":35,"column":1},"end":{"line":35,"column":1}},"key":"kCcHRBmfLA"},{"type":"strong","position":{"start":{"line":35,"column":1},"end":{"line":35,"column":1}},"children":[{"type":"text","value":"halve the FPS","position":{"start":{"line":35,"column":1},"end":{"line":35,"column":1}},"key":"P7DQ5RD5V9"}],"key":"Qgmy1wCLdQ"},{"type":"text","value":" when writing the output video.","position":{"start":{"line":35,"column":1},"end":{"line":35,"column":1}},"key":"rC1gdllNvl"}],"key":"QWEtBAJTvR"},{"type":"paragraph","position":{"start":{"line":38,"column":1},"end":{"line":38,"column":1}},"children":[{"type":"text","value":"Example:","position":{"start":{"line":38,"column":1},"end":{"line":38,"column":1}},"key":"RpEPOOFpxL"}],"key":"AGFVqlsMIo"},{"type":"list","ordered":false,"spread":false,"position":{"start":{"line":40,"column":1},"end":{"line":42,"column":1}},"children":[{"type":"listItem","spread":true,"position":{"start":{"line":40,"column":1},"end":{"line":40,"column":1}},"children":[{"type":"paragraph","children":[{"type":"text","value":"Input video: 120 FPS, 600 frames → 20 seconds","position":{"start":{"line":40,"column":1},"end":{"line":40,"column":1}},"key":"LSchhohsLh"}],"key":"IzFaxs34BN"}],"key":"WSBfPldoUF"},{"type":"listItem","spread":true,"position":{"start":{"line":41,"column":1},"end":{"line":42,"column":1}},"children":[{"type":"paragraph","children":[{"type":"text","value":"Output video: 60 FPS, 300 frames → still 20 seconds","position":{"start":{"line":41,"column":1},"end":{"line":41,"column":1}},"key":"ATqjGRcwxD"}],"key":"ei0mCY0jha"}],"key":"U4fKb71O9N"}],"key":"E9xadV1S78"},{"type":"paragraph","position":{"start":{"line":43,"column":1},"end":{"line":43,"column":1}},"children":[{"type":"text","value":"This preserves video timing.","position":{"start":{"line":43,"column":1},"end":{"line":43,"column":1}},"key":"SwaedONRZE"}],"key":"sT6jFP5HHT"},{"type":"thematicBreak","position":{"start":{"line":45,"column":1},"end":{"line":45,"column":1}},"key":"TMaUnb5Bj5"}],"key":"LtMTI2YDvl"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Make the Python Function","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"foosVgCq4z"}],"identifier":"make-the-python-function","label":"Make the Python Function","html_id":"make-the-python-function","implicit":true,"key":"SJ4IDUGtup"}],"key":"X8N604Qn3J"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"import os\nimport cv2\nfrom tqdm import tqdm\n\ndef reduce_frames_in_directory(directory_path: str):\n    # Supported video extensions\n    VIDEO_EXTENSIONS = ('.mp4', '.mov', '.avi', '.mkv', '.flv')\n\n    # List all video files in the directory\n    files = [f for f in os.listdir(directory_path) if f.lower().endswith(VIDEO_EXTENSIONS)]\n\n    if not files:\n        print(\"No video files found in the directory.\")\n        return\n\n    for file in files:\n        input_path = os.path.join(directory_path, file)\n        basename, ext = os.path.splitext(file)\n\n        output_filename = f\"{basename}_FrameReduced{ext}\"\n        output_path = os.path.join(directory_path, output_filename)\n\n        print(f\"\\nProcessing: {file}\")\n        \n        cap = cv2.VideoCapture(input_path)\n        if not cap.isOpened():\n            print(f\"Could not open {file}. Skipping.\")\n            continue\n        \n        # Read input video properties\n        input_fps = cap.get(cv2.CAP_PROP_FPS)\n        width  = int(cap.get(cv2.CAP_PROP_FRAME_WIDTH))\n        height = int(cap.get(cv2.CAP_PROP_FRAME_HEIGHT))\n\n        # New FPS = half the original\n        output_fps = input_fps / 2\n\n        # Video writer\n        fourcc = cv2.VideoWriter_fourcc(*\"mp4v\")\n        out = cv2.VideoWriter(output_path, fourcc, output_fps, (width, height))\n\n        frame_count = int(cap.get(cv2.CAP_PROP_FRAME_COUNT))\n        \n        # Loop through frames\n        for i in tqdm(range(frame_count), desc=f\"Writing {output_filename}\"):\n            ret, frame = cap.read()\n            if not ret:\n                break\n            \n            # Skip every other frame → keep even-numbered frames only\n            if i % 2 == 0:\n                out.write(frame)\n\n        cap.release()\n        out.release()\n\n        print(f\"Saved: {output_filename}\")\n\n","key":"HFZSzoBqt7"},{"type":"outputs","id":"QPi9XgTAYTRzVUHojpghZ","children":[],"key":"xCSvmI8bxk"}],"key":"ZTsKTHdNz2"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"RUN THE FUNCTION BELOW","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"OjCFAAwM0Y"}],"identifier":"run-the-function-below","label":"RUN THE FUNCTION BELOW","html_id":"run-the-function-below","implicit":true,"key":"cPNC22rzeK"}],"key":"tc1RhXONKm"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"# Example:\ndirectory_path = \"path/to/yours/videos\"\nreduce_frames_in_directory(directory_path)","key":"zL3ZXfKEb7"},{"type":"outputs","id":"_40SCQ99JWWxn6v9YwOza","children":[],"key":"pEOBMxWFqh"}],"key":"d1r6vOGjwN"}],"key":"iR0h5RnhJ8"},"references":{"