","position":{"start":{"line":26,"column":1},"end":{"line":26,"column":1}},"key":"Ozju3qYpFx"}],"identifier":"output-format","label":"Output Format","html_id":"output-format","implicit":true,"key":"cx9jaAvuqr"},{"type":"paragraph","position":{"start":{"line":27,"column":1},"end":{"line":29,"column":1}},"children":[{"type":"text","value":"For an input file like: ","position":{"start":{"line":27,"column":1},"end":{"line":27,"column":1}},"key":"ZAkUAN7CJa"},{"type":"inlineCode","value":"walking.mp4","position":{"start":{"line":27,"column":1},"end":{"line":27,"column":1}},"key":"gnM1lsMMZI"},{"type":"text","value":"\nThe output file will be: ","position":{"start":{"line":27,"column":1},"end":{"line":27,"column":1}},"key":"c4lpaNNdmU"},{"type":"inlineCode","value":"walking_FrameReduced.mp4","position":{"start":{"line":27,"column":1},"end":{"line":27,"column":1}},"key":"ENGU0g01fS"},{"type":"text","value":"\nin the ","position":{"start":{"line":27,"column":1},"end":{"line":27,"column":1}},"key":"mK2lKvwwMq"},{"type":"strong","position":{"start":{"line":27,"column":1},"end":{"line":27,"column":1}},"children":[{"type":"text","value":"same directory","position":{"start":{"line":27,"column":1},"end":{"line":27,"column":1}},"key":"CFmLKFAarE"}],"key":"cJNp1pn1kE"},{"type":"text","value":", and the video will keep its original duration even though half the frames are removed.","position":{"start":{"line":27,"column":1},"end":{"line":27,"column":1}},"key":"v2nO2r0NNq"}],"key":"lCKafa22KB"},{"type":"thematicBreak","position":{"start":{"line":31,"column":1},"end":{"line":31,"column":1}},"key":"qHDHUSB38N"},{"type":"heading","depth":1,"position":{"start":{"line":33,"column":1},"end":{"line":33,"column":1}},"children":[{"type":"text","value":"How We Keep the Original Duration","position":{"start":{"line":33,"column":1},"end":{"line":33,"column":1}},"key":"nOZF8Ny0BV"}],"identifier":"how-we-keep-the-original-duration","label":"How We Keep the Original Duration","html_id":"how-we-keep-the-original-duration","implicit":true,"key":"tabsymhCo8"},{"type":"paragraph","position":{"start":{"line":35,"column":1},"end":{"line":36,"column":1}},"children":[{"type":"text","value":"If we skip every other frame, we effectively output half the frames.","position":{"start":{"line":35,"column":1},"end":{"line":35,"column":1}},"key":"UbGYpR1Adc"},{"type":"break","position":{"start":{"line":35,"column":1},"end":{"line":35,"column":1}},"key":"dmlOvt8yvi"},{"type":"text","value":"To keep the video length the same, we also ","position":{"start":{"line":35,"column":1},"end":{"line":35,"column":1}},"key":"U9jRnrAspg"},{"type":"strong","position":{"start":{"line":35,"column":1},"end":{"line":35,"column":1}},"children":[{"type":"text","value":"halve the FPS","position":{"start":{"line":35,"column":1},"end":{"line":35,"column":1}},"key":"VbwTQ9SWbF"}],"key":"GbxyHSjO3N"},{"type":"text","value":" when writing the output video.","position":{"start":{"line":35,"column":1},"end":{"line":35,"column":1}},"key":"Kofc7lYZI0"}],"key":"lj1ZVd6aVb"},{"type":"paragraph","position":{"start":{"line":38,"column":1},"end":{"line":38,"column":1}},"children":[{"type":"text","value":"Example:","position":{"start":{"line":38,"column":1},"end":{"line":38,"column":1}},"key":"N7pHlDlQw2"}],"key":"QMxmaNktz1"},{"type":"list","ordered":false,"spread":false,"position":{"start":{"line":40,"column":1},"end":{"line":42,"column":1}},"children":[{"type":"listItem","spread":true,"position":{"start":{"line":40,"column":1},"end":{"line":40,"column":1}},"children":[{"type":"paragraph","children":[{"type":"text","value":"Input video: 120 FPS, 600 frames → 20 seconds","position":{"start":{"line":40,"column":1},"end":{"line":40,"column":1}},"key":"sihosCMads"}],"key":"CQMUe934Eo"}],"key":"ao5ozYUmCE"},{"type":"listItem","spread":true,"position":{"start":{"line":41,"column":1},"end":{"line":42,"column":1}},"children":[{"type":"paragraph","children":[{"type":"text","value":"Output video: 60 FPS, 300 frames → still 20 seconds","position":{"start":{"line":41,"column":1},"end":{"line":41,"column":1}},"key":"ZFq2vNXYgw"}],"key":"Fdp4fRzu5q"}],"key":"D9euyXnZF5"}],"key":"pfoWKpxCN6"},{"type":"paragraph","position":{"start":{"line":43,"column":1},"end":{"line":43,"column":1}},"children":[{"type":"text","value":"This preserves video timing.","position":{"start":{"line":43,"column":1},"end":{"line":43,"column":1}},"key":"FnUCOMe2vX"}],"key":"oNtP1wJEg1"},{"type":"thematicBreak","position":{"start":{"line":45,"column":1},"end":{"line":45,"column":1}},"key":"UcYnUXIzhY"}],"key":"M0GqfTTphh"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Make the Python Function","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"AraqqtheQQ"}],"identifier":"make-the-python-function","label":"Make the Python Function","html_id":"make-the-python-function","implicit":true,"key":"fJ0XizDCCj"}],"key":"k79Vz4Kl7b"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"import os\nimport cv2\nfrom tqdm import tqdm\n\ndef reduce_frames_in_directory(directory_path: str):\n    # Supported video extensions\n    VIDEO_EXTENSIONS = ('.mp4', '.mov', '.avi', '.mkv', '.flv')\n\n    # List all video files in the directory\n    files = [f for f in os.listdir(directory_path) if f.lower().endswith(VIDEO_EXTENSIONS)]\n\n    if not files:\n        print(\"No video files found in the directory.\")\n        return\n\n    for file in files:\n        input_path = os.path.join(directory_path, file)\n        basename, ext = os.path.splitext(file)\n\n        output_filename = f\"{basename}_FrameReduced{ext}\"\n        output_path = os.path.join(directory_path, output_filename)\n\n        print(f\"\\nProcessing: {file}\")\n        \n        cap = cv2.VideoCapture(input_path)\n        if not cap.isOpened():\n            print(f\"Could not open {file}. Skipping.\")\n            continue\n        \n        # Read input video properties\n        input_fps = cap.get(cv2.CAP_PROP_FPS)\n        width  = int(cap.get(cv2.CAP_PROP_FRAME_WIDTH))\n        height = int(cap.get(cv2.CAP_PROP_FRAME_HEIGHT))\n\n        # New FPS = half the original\n        output_fps = input_fps / 2\n\n        # Video writer\n        fourcc = cv2.VideoWriter_fourcc(*\"mp4v\")\n        out = cv2.VideoWriter(output_path, fourcc, output_fps, (width, height))\n\n        frame_count = int(cap.get(cv2.CAP_PROP_FRAME_COUNT))\n        \n        # Loop through frames\n        for i in tqdm(range(frame_count), desc=f\"Writing {output_filename}\"):\n            ret, frame = cap.read()\n            if not ret:\n                break\n            \n            # Skip every other frame → keep even-numbered frames only\n            if i % 2 == 0:\n                out.write(frame)\n\n        cap.release()\n        out.release()\n\n        print(f\"Saved: {output_filename}\")\n\n","key":"EQVAIp6OZ9"},{"type":"outputs","id":"smj3RroNvYBs_ayv3gwhj","children":[],"key":"VC9SciNWbs"}],"key":"penGWz9CwP"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"RUN THE FUNCTION BELOW","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"Y9Dwt4TZ5q"}],"identifier":"run-the-function-below","label":"RUN THE FUNCTION BELOW","html_id":"run-the-function-below","implicit":true,"key":"RbHm1LTZaD"}],"key":"sfaALbmRlj"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"# Example:\ndirectory_path = \"path/to/yours/videos\"\nreduce_frames_in_directory(directory_path)","key":"KInyO1XjUu"},{"type":"outputs","id":"2d52TR-Irwd5296Ed1bIs","children":[],"key":"bVK0UL7ILt"}],"key":"vIpOj9cpP4"}],"key":"bNYmttxI6h"},"references":{"cite":{"order":[],"data":{}}},"footer":{"navigation":{"prev":{"title":"Loading Data and Doing Useful Work — Video","url":"/ls100-video-00-getting-started","group":"Modules"},"next":{"title":"Video Chunker by Frame Count (OpenCV)","url":"/ls100-video-01-video-processing-video-chunker-by-f","group":"Modules"}}},"domain":"http://localhost:3000"}