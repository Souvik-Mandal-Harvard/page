olumn":1}},"key":"wcvRwDr2ws"}],"key":"ZXkiFpHtki"},{"type":"text","value":" Capture video from your webcam and record to a file.","position":{"start":{"line":5,"column":1},"end":{"line":5,"column":1}},"key":"jxhSWnFgAm"}],"key":"csAf26y0Ll"}],"key":"VwU5dH8uKS"}],"key":"KwEo7kFDJC"},{"type":"blockquote","position":{"start":{"line":7,"column":1},"end":{"line":7,"column":1}},"children":[{"type":"paragraph","position":{"start":{"line":7,"column":1},"end":{"line":7,"column":1}},"children":[{"type":"text","value":"Requirements: ","position":{"start":{"line":7,"column":1},"end":{"line":7,"column":1}},"key":"kIiaeDsxgf"},{"type":"inlineCode","value":"opencv-python","position":{"start":{"line":7,"column":1},"end":{"line":7,"column":1}},"key":"W013fyFaTx"},{"type":"text","value":" and ","position":{"start":{"line":7,"column":1},"end":{"line":7,"column":1}},"key":"HOmxW5Gc7W"},{"type":"inlineCode","value":"matplotlib","position":{"start":{"line":7,"column":1},"end":{"line":7,"column":1}},"key":"KdER2ipSJX"},{"type":"text","value":" (install with ","position":{"start":{"line":7,"column":1},"end":{"line":7,"column":1}},"key":"ZI76IBvXhq"},{"type":"inlineCode","value":"pip install opencv-python matplotlib","position":{"start":{"line":7,"column":1},"end":{"line":7,"column":1}},"key":"t8eTcjOz2g"},{"type":"text","value":" if needed).","position":{"start":{"line":7,"column":1},"end":{"line":7,"column":1}},"key":"TgaVzz8R07"}],"key":"lcVEBSkseW"}],"key":"uQ12QeIRta"}],"key":"WKmMbjQJbq"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"# Imports\nimport cv2\nimport numpy as np\nimport matplotlib.pyplot as plt\nfrom pathlib import Path\n","key":"RY00oTIe6T"},{"type":"outputs","id":"4Ibdk-8mq4RfHSweBOBmt","children":[],"key":"pCWSQRk4vk"}],"key":"lhQAIKcwAU"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"1) Load a video and inspect properties","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"ktj9iAKmWj"}],"identifier":"id-1-load-a-video-and-inspect-properties","label":"1) Load a video and inspect properties","html_id":"id-1-load-a-video-and-inspect-properties","implicit":true,"key":"HBxoCbFb7r"}],"key":"S7FOWA2pPh"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"video_path = Path(\"sample_video.mp4\")  # change to your file\ncap = cv2.VideoCapture(str(video_path))\n\nif not cap.isOpened():\n    print(\"Could not open\", video_path, \"- please set the correct path to a local video file.\")\nelse:\n    frame_count = int(cap.get(cv2.CAP_PROP_FRAME_COUNT))\n    fps = cap.get(cv2.CAP_PROP_FPS)\n    width  = int(cap.get(cv2.CAP_PROP_FRAME_WIDTH))\n    height = int(cap.get(cv2.CAP_PROP_FRAME_HEIGHT))\n    print(\"Frames:\", frame_count, \"FPS:\", fps, \"Resolution:\", (width, height))\n    cap.release()\n","key":"EPm91qo7bf"},{"type":"outputs","id":"VUq8k9bKMfATmC_hAmhIW","children":[],"key":"q9i2kct6Zx"}],"key":"k98iC71zjd"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"2) Read and show a few frames","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"AUi42sqovs"}],"identifier":"id-2-read-and-show-a-few-frames","label":"2) Read and show a few frames","html_id":"id-2-read-and-show-a-few-frames","implicit":true,"key":"uLxZWQaiT2"}],"key":"oaOtzehlbG"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"video_path = Path(\"sample_video.mp4\")  # change to your file\ncap = cv2.VideoCapture(str(video_path))\n\nframes_to_show = 5\nshown = 0\n\nif cap.isOpened():\n    while shown < frames_to_show:\n        ok, frame = cap.read()\n        if not ok:\n            break\n        rgb = cv2.cvtColor(frame, cv2.COLOR_BGR2RGB)\n        plt.figure()\n        plt.imshow(rgb)\n        plt.title(f\"Frame {shown+1}\")\n        plt.axis(\"off\")\n        shown += 1\n    cap.release()\nelse:\n    print(\"Open a valid video to preview frames.\")\n","key":"VJAeLuKV0d"},{"type":"outputs","id":"TjqfL5TkjvWmgirMlvX1W","children":[],"key":"gXQIF3TDNB"}],"key":"ceDXtWwF1S"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"3) Task — Extract every Nth frame and save as images","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"bpYL1yFeTs"}],"identifier":"id-3-task-extract-every-nth-frame-and-save-as-images","label":"3) Task — Extract every Nth frame and save as images","html_id":"id-3-task-extract-every-nth-frame-and-save-as-images","implicit":true,"key":"iW3ZXiqIOT"}],"key":"XPfiW9dx4X"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"# TODO: Set N and output folder, then run.\nN = 30  # save every 30th frame\nout_dir = Path(\"frames_out\"); out_dir.mkdir(exist_ok=True)\n\nvideo_path = Path(\"sample_video.mp4\")  # change to your file\ncap = cv2.VideoCapture(str(video_path))\n\nif cap.isOpened():\n    idx = 0\n    saved = 0\n    while True:\n        ok, frame = cap.read()\n        if not ok:\n            break\n        if idx % N == 0:\n            out_path = out_dir / f\"frame_{idx:06d}.png\"\n            cv2.imwrite(str(out_path), frame)\n            saved += 1\n        idx += 1\n    cap.release()\n    print(f\"Saved {saved} frames to\", out_dir)\nelse:\n    print(\"Open a valid video to extract frames.\")","key":"SUB28wSVsL"},{"type":"outputs","id":"drM_ES19KdCph_GpTB8O_","children":[],"key":"bEBwkDtqkQ"}],"key":"uvZIGa2TBu"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"4) Fun Task — Capture webcam and record to a file","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"wVDEYYYnqU"}],"identifier":"id-4-fun-task-capture-webcam-and-record-to-a-file","label":"4) Fun Task — Capture webcam and record to a file","html_id":"id-4-fun-task-capture-webcam-and-record-to-a-file","implicit":true,"key":"thrwhQsuF8"}],"key":"Yoil7Zvyxe"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"# Requires a local machine with a webcam.\n# It may not work in hosted environments.\n\nout_path = Path(\"webcam_capture.mp4\")\nfourcc = cv2.VideoWriter_fourcc(*\"mp4v\")\nfps = 20.0\nsize = (640, 480)\n\ncap = cv2.VideoCapture(0)  # device 0\nwriter = cv2.VideoWriter(str(out_path), fourcc, fps, size)\n\nif not cap.isOpened():\n    print(\"Webcam not available.\")\nelse:\n    print(\"Press 'q' in the video window to stop recording...\")\n    while True:\n        ok, frame = cap.read()\n        if not ok:\n            break\n        frame = cv2.resize(frame, size)\n        writer.write(frame)\n        cv2.imshow(\"Recording... (press q to quit)\", frame)\n        if cv2.waitKey(1) & 0xFF == ord('q'):\n            break\n\n    cap.release()\n    writer.release()\n    cv2.destroyAllWindows()\n    print(\"Saved to\", out_path)\n","key":"o5q3i0HovW"},{"type":"outputs","id":"N1uPKyLTjsdQymqZiwde5","children":[],"key":"q62fn1ki7P"}],"key":"Gv84A3LDa7"}],"key":"qGLkNNFo7M"},"references":{"cite":{"order":[],"data":{}}},"footer":{"navigation":{"prev":{"title":"Module 01A — Video Data","short_title":"01A · Video Data","url":"/module-01a-video-data","group":"Modules"},"next":{"title":"Frame Reduction Script — Understanding the Packages","short_title":"Notebook 02 · Frame Reduction","url":"/ls100-module-01a-video-data-content-02-stage-01-vi","group":"Modules"}}},"domain":"http://localhost:3000"}