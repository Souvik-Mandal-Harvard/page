"JVjPpQle_2Z2IR9UVbBF8","children":[],"key":"UkMOHn0CiY"}],"key":"kk5Rcsl3io"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"1) Load a video and inspect properties","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"XSZipHP9jH"}],"identifier":"id-1-load-a-video-and-inspect-properties","label":"1) Load a video and inspect properties","html_id":"id-1-load-a-video-and-inspect-properties","implicit":true,"key":"ZHvtYQ7igO"}],"key":"d7MQg8TIwL"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"video_path = Path(\"sample_video.mp4\")  # change to your file\ncap = cv2.VideoCapture(str(video_path))\n\nif not cap.isOpened():\n    print(\"Could not open\", video_path, \"- please set the correct path to a local video file.\")\nelse:\n    frame_count = int(cap.get(cv2.CAP_PROP_FRAME_COUNT))\n    fps = cap.get(cv2.CAP_PROP_FPS)\n    width  = int(cap.get(cv2.CAP_PROP_FRAME_WIDTH))\n    height = int(cap.get(cv2.CAP_PROP_FRAME_HEIGHT))\n    print(\"Frames:\", frame_count, \"FPS:\", fps, \"Resolution:\", (width, height))\n    cap.release()\n","key":"CZ0UhSBT3j"},{"type":"outputs","id":"GC3aXQg_mx2XV4UOczRBa","children":[],"key":"jH4Wh2BLXU"}],"key":"W0aVLIvWMi"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"2) Read and show a few frames","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"xSTC4fYB2d"}],"identifier":"id-2-read-and-show-a-few-frames","label":"2) Read and show a few frames","html_id":"id-2-read-and-show-a-few-frames","implicit":true,"key":"i7h57ziOiD"}],"key":"k9kPH6BM9S"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"video_path = Path(\"sample_video.mp4\")  # change to your file\ncap = cv2.VideoCapture(str(video_path))\n\nframes_to_show = 5\nshown = 0\n\nif cap.isOpened():\n    while shown < frames_to_show:\n        ok, frame = cap.read()\n        if not ok:\n            break\n        rgb = cv2.cvtColor(frame, cv2.COLOR_BGR2RGB)\n        plt.figure()\n        plt.imshow(rgb)\n        plt.title(f\"Frame {shown+1}\")\n        plt.axis(\"off\")\n        shown += 1\n    cap.release()\nelse:\n    print(\"Open a valid video to preview frames.\")\n","key":"qkvyc1AUOd"},{"type":"outputs","id":"NUzGYwTOQLfNuuT1li0g1","children":[],"key":"cBGRXCYGTZ"}],"key":"cGNe2CfvFg"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"3) Task — Extract every Nth frame and save as images","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"LnLrQQ8Dez"}],"identifier":"id-3-task-extract-every-nth-frame-and-save-as-images","label":"3) Task — Extract every Nth frame and save as images","html_id":"id-3-task-extract-every-nth-frame-and-save-as-images","implicit":true,"key":"oiVQ0OVUtg"}],"key":"KuRbLXo9YA"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"# TODO: Set N and output folder, then run.\nN = 30  # save every 30th frame\nout_dir = Path(\"frames_out\"); out_dir.mkdir(exist_ok=True)\n\nvideo_path = Path(\"sample_video.mp4\")  # change to your file\ncap = cv2.VideoCapture(str(video_path))\n\nif cap.isOpened():\n    idx = 0\n    saved = 0\n    while True:\n        ok, frame = cap.read()\n        if not ok:\n            break\n        if idx % N == 0:\n            out_path = out_dir / f\"frame_{idx:06d}.png\"\n            cv2.imwrite(str(out_path), frame)\n            saved += 1\n        idx += 1\n    cap.release()\n    print(f\"Saved {saved} frames to\", out_dir)\nelse:\n    print(\"Open a valid video to extract frames.\")","key":"s8nwzIniE2"},{"type":"outputs","id":"h4mgWdbJJEZWHhUw3HgPw","children":[],"key":"XebaCFBIcA"}],"key":"kZt2MzUJAP"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"4) Fun Task — Capture webcam and record to a file","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"e6YohGmhOh"}],"identifier":"id-4-fun-task-capture-webcam-and-record-to-a-file","label":"4) Fun Task — Capture webcam and record to a file","html_id":"id-4-fun-task-capture-webcam-and-record-to-a-file","implicit":true,"key":"EmpjxuX5Pg"}],"key":"CGg1zEDnPg"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"# Requires a local machine with a webcam.\n# It may not work in hosted environments.\n\nout_path = Path(\"webcam_capture.mp4\")\nfourcc = cv2.VideoWriter_fourcc(*\"mp4v\")\nfps = 20.0\nsize = (640, 480)\n\ncap = cv2.VideoCapture(0)  # device 0\nwriter = cv2.VideoWriter(str(out_path), fourcc, fps, size)\n\nif not cap.isOpened():\n    print(\"Webcam not available.\")\nelse:\n    print(\"Press 'q' in the video window to stop recording...\")\n    while True:\n        ok, frame = cap.read()\n        if not ok:\n            break\n        frame = cv2.resize(frame, size)\n        writer.write(frame)\n        cv2.imshow(\"Recording... (press q to quit)\", frame)\n        if cv2.waitKey(1) & 0xFF == ord('q'):\n            break\n\n    cap.release()\n    writer.release()\n    cv2.destroyAllWindows()\n    print(\"Saved to\", out_path)\n","key":"wO5g7wZLOP"},{"type":"outputs","id":"J9VmvZdRVlx1Hw6rz5wjk","children":[],"key":"kPkLW59tk4"}],"key":"yfG0TNtQSG"}],"key":"M3dOKwJ2kt"},"references":{"cite":{"order":[],"data":{}}},"footer":{"navigation":{"prev":{"title":"Module 01A — Video Data","short_title":"01A · Video Data","url":"/module-01a-video-data","group":"Modules"},"next":{"title":"Frame Reduction Script — Understanding the Packages","short_title":"Notebook 02 · Frame Reduction","url":"/ls100-module-01a-video-data-content-02-stage-01-vi","group":"Modules"}}},"domain":"http://localhost:3000"}