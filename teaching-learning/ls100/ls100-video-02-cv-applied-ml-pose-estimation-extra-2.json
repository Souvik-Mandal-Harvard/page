":{"line":4,"column":1}},"children":[{"type":"text","value":"ByteTrack","position":{"start":{"line":4,"column":1},"end":{"line":4,"column":1}},"key":"iAC8BL7HHE"}],"key":"ceDw7BNJx0"},{"type":"text","value":" for stable ","position":{"start":{"line":4,"column":1},"end":{"line":4,"column":1}},"key":"mGieUUiTW4"},{"type":"inlineCode","value":"track_id","position":{"start":{"line":4,"column":1},"end":{"line":4,"column":1}},"key":"W0HvRZT5df"},{"type":"text","value":".","position":{"start":{"line":4,"column":1},"end":{"line":4,"column":1}},"key":"oIylnSaETf"}],"key":"aup81vJxsO"}],"key":"Tz4l4JHxCl"},{"type":"listItem","spread":true,"position":{"start":{"line":5,"column":1},"end":{"line":5,"column":1}},"children":[{"type":"paragraph","children":[{"type":"text","value":"Saves annotated video under ","position":{"start":{"line":5,"column":1},"end":{"line":5,"column":1}},"key":"TwZGxwZNLg"},{"type":"inlineCode","value":"OUTPUT_DIR/<run_name>/...","position":{"start":{"line":5,"column":1},"end":{"line":5,"column":1}},"key":"osNeRSG6dO"}],"key":"ZlLUzqBRdY"}],"key":"rwiVPEHdz9"},{"type":"listItem","spread":true,"position":{"start":{"line":6,"column":1},"end":{"line":6,"column":1}},"children":[{"type":"paragraph","children":[{"type":"text","value":"Saves CSV under ","position":{"start":{"line":6,"column":1},"end":{"line":6,"column":1}},"key":"N5Vp26JZAi"},{"type":"inlineCode","value":"OUTPUT_DIR/<run_name>_keypoints.csv","position":{"start":{"line":6,"column":1},"end":{"line":6,"column":1}},"key":"TLcqfdeAjR"}],"key":"DIVIotoXHg"}],"key":"TZznayLjlr"},{"type":"listItem","spread":true,"position":{"start":{"line":7,"column":1},"end":{"line":7,"column":1}},"children":[{"type":"paragraph","children":[{"type":"text","value":"The pipeline supports ","position":{"start":{"line":7,"column":1},"end":{"line":7,"column":1}},"key":"XtpyVl6Kcf"},{"type":"strong","position":{"start":{"line":7,"column":1},"end":{"line":7,"column":1}},"children":[{"type":"text","value":"Robust Export","position":{"start":{"line":7,"column":1},"end":{"line":7,"column":1}},"key":"dGNtCQ63TL"}],"key":"FyXcEASivQ"},{"type":"text","value":" (handles missing/partial keypoints) - guarding against frames/people that return zero or partial keypoints by filling ","position":{"start":{"line":7,"column":1},"end":{"line":7,"column":1}},"key":"VenbDzNArE"},{"type":"inlineCode","value":"None","position":{"start":{"line":7,"column":1},"end":{"line":7,"column":1}},"key":"LMNkYpdfSb"},{"type":"text","value":" values instead of indexing into an empty array.","position":{"start":{"line":7,"column":1},"end":{"line":7,"column":1}},"key":"s9aPKfxYTh"}],"key":"ErvwsG5v8C"}],"key":"knlECBIbNb"}],"key":"CmOClIBiWJ"}],"key":"WtydwJcxe3"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"\n# DO NOT CHANGE ANYTHING IN THIS CELL\ndef process_video_to_csv(\n    input_video: str,\n    output_dir: str,\n    model: YOLO,\n    conf: float = 0.25,\n    iou: float = 0.5,\n    imgsz: int = 640,\n    tracker: str = \"bytetrack.yaml\",\n    run_name: str = \"run1\",\n) -> dict:\n    \"\"\"Run YOLOv8-Pose tracking on a video and export keypoints to CSV.\n\n    Returns: {'csv_path', 'annotated_video_dir', 'annotated_video'}\n    \"\"\"\n    os.makedirs(output_dir, exist_ok=True)\n    fps, total_frames = get_video_fps_frames(input_video)\n    print(f\"Video FPS: {fps:.2f}, frames: {total_frames}\")\n\n    # Ensure ByteTrack dep is active (Ultralytics auto-installs lapx if needed; reruns handle it)\n    results = model.track(\n        source=input_video,\n        conf=conf,\n        iou=iou,\n        imgsz=imgsz,\n        device=0,\n        verbose=False,\n        stream=False,   # keep False for auto-saved annotated video\n        save=True,\n        project=output_dir,\n        name=run_name,\n        tracker=tracker,\n        persist=True\n    )\n\n    if not isinstance(results, list):\n        results = list(results)\n\n    rows = []\n    for frame_idx, r in enumerate(tqdm(results, desc=\"Extracting keypoints\")):\n        ts_ms = int(round(frame_idx * 1000.0 / max(fps, 1e-6)))\n\n        # Skip if no keypoints\n        if r.keypoints is None or r.keypoints.xy is None or len(r.keypoints.xy) == 0:\n            continue\n\n        kps_xy = r.keypoints.xy  # shape: [num_people, K, 2] (K may be 0 or < 17 sometimes)\n        kps_conf = getattr(r.keypoints, 'conf', None)\n        boxes = r.boxes\n\n        # Track IDs (optional; may be missing)\n        ids = None\n        if boxes is not None and getattr(boxes, 'id', None) is not None:\n            try:\n                ids = boxes.id.detach().cpu().numpy().astype(int)\n            except Exception:\n                ids = None\n\n        # Detection confidences\n        det_conf = None\n        if boxes is not None and getattr(boxes, 'conf', None) is not None:\n            try:\n                det_conf = boxes.conf.detach().cpu().numpy()\n            except Exception:\n                det_conf = None\n\n        num_people = kps_xy.shape[0]\n        for i in range(num_people):\n            # Pull per-person tensors/arrays\n            kpi = kps_xy[i]\n            if hasattr(kpi, 'detach'):\n                kpi = kpi.detach().cpu().numpy()  # shape: [K, 2]\n\n            kpci = None\n            if kps_conf is not None:\n                kpci = kps_conf[i]\n                if hasattr(kpci, 'detach'):\n                    kpci = kpci.detach().cpu().numpy()  # shape: [K]\n\n            K = kpi.shape[0] if kpi is not None and hasattr(kpi, 'shape') else 0\n\n            track_id = int(ids[i]) if ids is not None and i < len(ids) else -1\n            this_det_conf = float(det_conf[i]) if det_conf is not None and i < len(det_conf) else None\n\n            row = {\n                \"video_file\": os.path.basename(input_video),\n                \"frame_idx\": frame_idx,\n                \"timestamp_ms\": ts_ms,\n                \"track_id\": track_id,\n                \"det_conf\": this_det_conf\n            }\n\n            # Fill keypoints, guarding for K < 17 (or K == 0)\n            for kp_idx, kp_name in enumerate(COCO_KP_NAMES):\n                if K > kp_idx:\n                    x = float(kpi[kp_idx, 0])\n                    y = float(kpi[kp_idx, 1])\n                    row[f\"{kp_name}_x\"] = x\n                    row[f\"{kp_name}_y\"] = y\n                    if kpci is not None and kp_idx < len(kpci):\n                        row[f\"{kp_name}_conf\"] = float(kpci[kp_idx])\n                    else:\n                        row[f\"{kp_name}_conf\"] = None\n                else:\n                    row[f\"{kp_name}_x\"] = None\n                    row[f\"{kp_name}_y\"] = None\n                    row[f\"{kp_name}_conf\"] = None\n\n            rows.append(row)\n\n    df = pd.DataFrame(rows)\n    csv_path = os.path.join(output_dir, f\"{run_name}_keypoints.csv\")\n    df.to_csv(csv_path, index=False)\n    print(f\"Saved CSV: {csv_path}  ({len(df):,} rows)\")\n\n    ann_dir = os.path.join(output_dir, run_name)\n    ann_video = None\n    if os.path.isdir(ann_dir):\n        for f in os.listdir(ann_dir):\n            if f.lower().endswith((\".mp4\", \".avi\", \".mov\", \".mkv\")):\n                ann_video = os.path.join(ann_dir, f); break\n\n    return {\"csv_path\": csv_path, \"annotated_video_dir\": ann_dir if os.path.isdir(ann_dir) else None, \"annotated_video\": ann_video}\n","key":"N2WYgQee7t"},{"type":"outputs","id":"Pz0xKL9nKCdhx1qA_Uy7T","children":[],"key":"dqZh9i0q8N"}],"key":"baiQx21XBl"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"9) Batch Run — Process Every Video in the Folder","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"WLuG4a7SNu"}],"identifier":"id-9-batch-run-process-every-video-in-the-folder","label":"9) Batch Run — Process Every Video 