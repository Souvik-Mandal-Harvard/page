},{"type":"text","value":" exist.","position":{"start":{"line":7,"column":1},"end":{"line":7,"column":1}},"key":"v1ckl3Lnpt"}],"key":"nF00FYUh0B"}],"key":"Wl0rpFzAjj"}],"key":"Ta0M5ilDE9"}],"key":"zBej2XZRNv"},{"type":"listItem","spread":true,"position":{"start":{"line":9,"column":1},"end":{"line":12,"column":1}},"children":[{"type":"paragraph","position":{"start":{"line":9,"column":1},"end":{"line":9,"column":1}},"children":[{"type":"strong","position":{"start":{"line":9,"column":1},"end":{"line":9,"column":1}},"children":[{"type":"text","value":"Segment computation functions","position":{"start":{"line":9,"column":1},"end":{"line":9,"column":1}},"key":"A7pCgGN2Hv"}],"key":"OQygTkl4NE"}],"key":"vaTQpenq8O"},{"type":"list","ordered":false,"spread":false,"position":{"start":{"line":10,"column":1},"end":{"line":12,"column":1}},"children":[{"type":"listItem","spread":true,"position":{"start":{"line":10,"column":1},"end":{"line":10,"column":1}},"children":[{"type":"paragraph","children":[{"type":"inlineCode","value":"compute_first_segment(duration)","position":{"start":{"line":10,"column":1},"end":{"line":10,"column":1}},"key":"L95ahzDeBt"},{"type":"text","value":" → first 60 seconds.","position":{"start":{"line":10,"column":1},"end":{"line":10,"column":1}},"key":"VqOZ6EYmGC"}],"key":"aM97hQy4cE"}],"key":"XmLj1XQ9Cg"},{"type":"listItem","spread":true,"position":{"start":{"line":11,"column":1},"end":{"line":11,"column":1}},"children":[{"type":"paragraph","children":[{"type":"inlineCode","value":"compute_middle_segment(duration)","position":{"start":{"line":11,"column":1},"end":{"line":11,"column":1}},"key":"hlUEOqJyH9"},{"type":"text","value":" → 60 seconds around the middle.","position":{"start":{"line":11,"column":1},"end":{"line":11,"column":1}},"key":"SwzzLUTSxp"}],"key":"AgKiFS0Ity"}],"key":"tgfIu5egHi"},{"type":"listItem","spread":true,"position":{"start":{"line":12,"column":1},"end":{"line":12,"column":1}},"children":[{"type":"paragraph","children":[{"type":"inlineCode","value":"compute_last_segment(duration)","position":{"start":{"line":12,"column":1},"end":{"line":12,"column":1}},"key":"CxNzqWX0BA"},{"type":"text","value":" → last 60 seconds.","position":{"start":{"line":12,"column":1},"end":{"line":12,"column":1}},"key":"sqVpPrIZJB"}],"key":"HlnqcIYGhv"}],"key":"kDUO0nsyPq"}],"key":"l4szzNb8sp"}],"key":"DSwWSHCiSu"}],"key":"wqAKcm2OHF"}],"key":"sqH81uhq0u"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"def find_video_pairs(directory: Path):\n    \"\"\"\n    Find pairs of videos in `directory` where filenames follow:\n        <prefix>_<index>.<ext>\n    and both index '1' and '2' exist for the same (prefix, ext).\n\n    Returns:\n        List of tuples: [(path_to_prefix_1, path_to_prefix_2), ...]\n    \"\"\"\n    all_files = [\n        p for p in directory.iterdir()\n        if p.is_file() and p.suffix.lower() in VIDEO_EXTENSIONS\n    ]\n\n    groups = {}\n    pattern = re.compile(r\"^(?P<prefix>.+)_(?P<index>\\d+)$\")  # match <prefix>_<index>\n\n    for path in all_files:\n        match = pattern.match(path.stem)\n        if not match:\n            continue\n\n        prefix = match.group(\"prefix\")\n        index = match.group(\"index\")\n        key = (prefix, path.suffix.lower())\n\n        if key not in groups:\n            groups[key] = {}\n        groups[key][index] = path\n\n    pairs = []\n    for (prefix, ext), index_map in groups.items():\n        if \"1\" in index_map and \"2\" in index_map:\n            pairs.append((index_map[\"1\"], index_map[\"2\"]))\n\n    return pairs\n\n\ndef compute_first_segment(duration: float, seg_len: float = SEGMENT_LENGTH_SECONDS):\n    \"\"\"Return (start, end) for the first segment, up to seg_len seconds.\"\"\"\n    start = 0.0\n    end = min(seg_len, duration)\n    return start, end\n\n\ndef compute_middle_segment(duration: float, seg_len: float = SEGMENT_LENGTH_SECONDS):\n    \"\"\"\n    Return (start, end) for a seg_len-second window around the middle.\n    If the video is shorter than seg_len, return the whole video.\n    \"\"\"\n    if duration <= 0:\n        return 0.0, 0.0\n\n    if duration <= seg_len:\n        return 0.0, duration\n\n    mid = duration / 2.0\n    start = max(0.0, mid - seg_len / 2.0)\n    end = start + seg_len\n\n    if end > duration:\n        end = duration\n        start = max(0.0, end - seg_len)\n\n    return start, end\n\n\ndef compute_last_segment(duration: float, seg_len: float = SEGMENT_LENGTH_SECONDS):\n    \"\"\"\n    Return (start, end) for the last seg_len seconds.\n    If the video is shorter than seg_len, return the whole video.\n    \"\"\"\n    if duration <= 0:\n        return 0.0, 0.0\n\n    if duration <= seg_len:\n        return 0.0, duration\n\n    start = max(0.0, duration - seg_len)\n    end = duration\n    return start, end","key":"hYBjHToPjk"},{"type":"outputs","id":"nPTLv7ARFwiLmXI5SXryT","children":[],"key":"W0x5IgVUnV"}],"key":"RHzAcPvPBW"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":3,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Helper functions: resizing and writing clips","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"hycMWdOqJU"}],"identifier":"helper-functions-resizing-and-writing-clips","label":"Helper functions: resizing and writing clips","html_id":"helper-functions-resizing-and-writing-clips","implicit":true,"key":"qoQXDpAhse"},{"type":"paragraph","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"children":[{"type":"text","value":"The functions below handle resizing and saving clips:","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"dr8t1YEpyO"}],"key":"ydREEBjJal"},{"type":"list","ordered":true,"start":1,"spread":false,"position":{"start":{"line":5,"column":1},"end":{"line":16,"column":1}},"children":[{"type":"listItem","spread":true,"po