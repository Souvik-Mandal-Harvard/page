},{"type":"text","value":" exist.","position":{"start":{"line":7,"column":1},"end":{"line":7,"column":1}},"key":"cCJg9aFn66"}],"key":"hl1JuP5XYM"}],"key":"FoB8oBaCHD"}],"key":"oxJjzKw4Pp"}],"key":"sebKdR9lLI"},{"type":"listItem","spread":true,"position":{"start":{"line":9,"column":1},"end":{"line":12,"column":1}},"children":[{"type":"paragraph","position":{"start":{"line":9,"column":1},"end":{"line":9,"column":1}},"children":[{"type":"strong","position":{"start":{"line":9,"column":1},"end":{"line":9,"column":1}},"children":[{"type":"text","value":"Segment computation functions","position":{"start":{"line":9,"column":1},"end":{"line":9,"column":1}},"key":"a7knXajxYi"}],"key":"Ji5gAJdN8q"}],"key":"N85MR254EW"},{"type":"list","ordered":false,"spread":false,"position":{"start":{"line":10,"column":1},"end":{"line":12,"column":1}},"children":[{"type":"listItem","spread":true,"position":{"start":{"line":10,"column":1},"end":{"line":10,"column":1}},"children":[{"type":"paragraph","children":[{"type":"inlineCode","value":"compute_first_segment(duration)","position":{"start":{"line":10,"column":1},"end":{"line":10,"column":1}},"key":"Uo90HDkv4I"},{"type":"text","value":" → first 60 seconds.","position":{"start":{"line":10,"column":1},"end":{"line":10,"column":1}},"key":"LsTAGKlxQe"}],"key":"ssCpFxYgrK"}],"key":"Ge3qFV8nb7"},{"type":"listItem","spread":true,"position":{"start":{"line":11,"column":1},"end":{"line":11,"column":1}},"children":[{"type":"paragraph","children":[{"type":"inlineCode","value":"compute_middle_segment(duration)","position":{"start":{"line":11,"column":1},"end":{"line":11,"column":1}},"key":"YAjv3WaGOZ"},{"type":"text","value":" → 60 seconds around the middle.","position":{"start":{"line":11,"column":1},"end":{"line":11,"column":1}},"key":"bcV7daeQP1"}],"key":"vQnn9YMci6"}],"key":"CIU29tmrPj"},{"type":"listItem","spread":true,"position":{"start":{"line":12,"column":1},"end":{"line":12,"column":1}},"children":[{"type":"paragraph","children":[{"type":"inlineCode","value":"compute_last_segment(duration)","position":{"start":{"line":12,"column":1},"end":{"line":12,"column":1}},"key":"MS2R8fMnuf"},{"type":"text","value":" → last 60 seconds.","position":{"start":{"line":12,"column":1},"end":{"line":12,"column":1}},"key":"vAxuoQJzXP"}],"key":"PEGjP72eBc"}],"key":"bhWymdnjLB"}],"key":"dqGHy5VOq8"}],"key":"YlxCNhd0xq"}],"key":"TSZ56ufl0k"}],"key":"Bk18T0SA4I"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"def find_video_pairs(directory: Path):\n    \"\"\"\n    Find pairs of videos in `directory` where filenames follow:\n        <prefix>_<index>.<ext>\n    and both index '1' and '2' exist for the same (prefix, ext).\n\n    Returns:\n        List of tuples: [(path_to_prefix_1, path_to_prefix_2), ...]\n    \"\"\"\n    all_files = [\n        p for p in directory.iterdir()\n        if p.is_file() and p.suffix.lower() in VIDEO_EXTENSIONS\n    ]\n\n    groups = {}\n    pattern = re.compile(r\"^(?P<prefix>.+)_(?P<index>\\d+)$\")  # match <prefix>_<index>\n\n    for path in all_files:\n        match = pattern.match(path.stem)\n        if not match:\n            continue\n\n        prefix = match.group(\"prefix\")\n        index = match.group(\"index\")\n        key = (prefix, path.suffix.lower())\n\n        if key not in groups:\n            groups[key] = {}\n        groups[key][index] = path\n\n    pairs = []\n    for (prefix, ext), index_map in groups.items():\n        if \"1\" in index_map and \"2\" in index_map:\n            pairs.append((index_map[\"1\"], index_map[\"2\"]))\n\n    return pairs\n\n\ndef compute_first_segment(duration: float, seg_len: float = SEGMENT_LENGTH_SECONDS):\n    \"\"\"Return (start, end) for the first segment, up to seg_len seconds.\"\"\"\n    start = 0.0\n    end = min(seg_len, duration)\n    return start, end\n\n\ndef compute_middle_segment(duration: float, seg_len: float = SEGMENT_LENGTH_SECONDS):\n    \"\"\"\n    Return (start, end) for a seg_len-second window around the middle.\n    If the video is shorter than seg_len, return the whole video.\n    \"\"\"\n    if duration <= 0:\n        return 0.0, 0.0\n\n    if duration <= seg_len:\n        return 0.0, duration\n\n    mid = duration / 2.0\n    start = max(0.0, mid - seg_len / 2.0)\n    end = start + seg_len\n\n    if end > duration:\n        end = duration\n        start = max(0.0, end - seg_len)\n\n    return start, end\n\n\ndef compute_last_segment(duration: float, seg_len: float = SEGMENT_LENGTH_SECONDS):\n    \"\"\"\n    Return (start, end) for the last seg_len seconds.\n    If the video is shorter than seg_len, return the whole video.\n    \"\"\"\n    if duration <= 0:\n        return 0.0, 0.0\n\n    if duration <= seg_len:\n        return 0.0, duration\n\n    start = max(0.0, duration - seg_len)\n    end = duration\n    return start, end","key":"s512xpWrPe"},{"type":"outputs","id":"L_T5eTCoVNsj1Q6yJxvDH","children":[],"key":"kTohIR2Kc8"}],"key":"hVUlQPCZX1"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":3,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Helper functions: resizing and writing clips","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"G9f8jcoCsm"}],"identifier":"helper-functions-resizing-and-writing-clips","label":"Helper functions: resizing and writing clips","html_id":"helper-functions-resizing-and-writing-clips","implicit":true,"key":"Mu2371VS8F"},{"type":"paragraph","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"children":[{"type":"text","value":"The functions below handle resizing and saving clips:","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"WAxjhuMefh"}],"key":"JSixzBBL1U"},{"type":"list","ordered":true,"start":1,"spread":false,"position":{"start":{"line":5,"column":1},"end":{"line":16,"column":1}},"children":[{"type":"listItem","spread":true,"po