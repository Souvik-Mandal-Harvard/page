ue":"mp4v","position":{"start":{"line":6,"column":1},"end":{"line":6,"column":1}},"key":"GEWW4655yO"},{"type":"text","value":"; try ","position":{"start":{"line":6,"column":1},"end":{"line":6,"column":1}},"key":"t5v0PGV3n4"},{"type":"inlineCode","value":"avc1","position":{"start":{"line":6,"column":1},"end":{"line":6,"column":1}},"key":"IpGaivRnrZ"},{"type":"text","value":" or ","position":{"start":{"line":6,"column":1},"end":{"line":6,"column":1}},"key":"ptk3MI4ZGI"},{"type":"inlineCode","value":"H264","position":{"start":{"line":6,"column":1},"end":{"line":6,"column":1}},"key":"oIFOvkXZXp"},{"type":"text","value":" if available on your system for smaller files).","position":{"start":{"line":6,"column":1},"end":{"line":6,"column":1}},"key":"Lt549iYX59"}],"key":"IwfCcMlrEq"}],"key":"UTwoVLKzMS"}],"key":"qfpuVUbTQh"}],"key":"m1tfcc1Hdd"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"\nfrom pathlib import Path\n\n# >>> EDIT THESE <<<\ninput_path = Path(\"/Users/souvikmandal/Documents/example.mp4\")\nchunk_num_frame = 1000\ncodec = \"mp4v\"   # alternatives: \"avc1\", \"H264\" (requires proper system codecs)\n\n# No edits needed below\ninput_path = input_path.expanduser().resolve()\ninput_path\n","key":"eS77T0BZR9"},{"type":"outputs","id":"AH6Y8NYdLBAktyaKCpxB4","children":[],"key":"xStAlglew0"}],"key":"j5dNvWu5uX"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":2,"column":1},"end":{"line":2,"column":1}},"children":[{"type":"text","value":"2) Core Function","position":{"start":{"line":2,"column":1},"end":{"line":2,"column":1}},"key":"fzGOpM2P4w"}],"identifier":"id-2-core-function","label":"2) Core Function","html_id":"id-2-core-function","implicit":true,"key":"HfFP8W2fHB"},{"type":"paragraph","position":{"start":{"line":4,"column":1},"end":{"line":4,"column":1}},"children":[{"type":"text","value":"The function below reads frames sequentially and writes chunk files with the same FPS and resolution as the source video.","position":{"start":{"line":4,"column":1},"end":{"line":4,"column":1}},"key":"WtxX9lkSQy"}],"key":"sdWFk96wIS"}],"key":"vbNb7JT6qZ"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"\nimport sys\nimport cv2\n\ndef split_video_by_frames(input_path: Path, chunk_num_frame: int, codec: str = \"mp4v\") -> Path:\n    \"\"\"Split a video into consecutive chunks by frame count.\n\n    Args:\n        input_path: Path to the input video.\n        chunk_num_frame: Number of frames per chunk (must be > 0).\n        codec: FourCC for output encoding (e.g., 'mp4v', 'avc1', 'H264').\n\n    Returns:\n        Path to the output directory where chunks are saved.\n    \"\"\"\n    if not input_path.exists() or not input_path.is_file():\n        raise FileNotFoundError(f\"Input file not found: {input_path}\")\n    if chunk_num_frame <= 0:\n        raise ValueError(\"--chunk_num_frame must be a positive integer.\")\n\n    stem = input_path.stem                      # e.g., \"example\"\n    parent_dir = input_path.parent              # e.g., user/xyz/documents/videos\n    output_dir = parent_dir / stem              # e.g., user/xyz/documents/videos/example\n    output_dir.mkdir(parents=True, exist_ok=True)\n\n    cap = cv2.VideoCapture(str(input_path))\n    if not cap.isOpened():\n        raise RuntimeError(f\"Could not open video: {input_path}\")\n\n    fps = cap.get(cv2.CAP_PROP_FPS)\n    width = int(cap.get(cv2.CAP_PROP_FRAME_WIDTH))\n    height = int(cap.get(cv2.CAP_PROP_FRAME_HEIGHT))\n\n    if fps <= 0 or width <= 0 or height <= 0:\n        print(\"[WARN] Could not read video metadata reliably. Proceeding with defaults if possible.\", file=sys.stderr)\n\n    fourcc = cv2.VideoWriter_fourcc(*codec)\n    chunk_idx = 1\n    frames_in_current_chunk = 0\n    total_frames = 0\n    writer = None\n\n    def start_new_writer(index: int):\n        nonlocal writer, frames_in_current_chunk\n        out_name = f\"{stem}_chunk{index:02d}.mp4\"\n        out_path = output_dir / out_name\n        writer = cv2.VideoWriter(str(out_path), fourcc, fps if fps > 0 else 30.0, (width, height))\n        if not writer.isOpened():\n            cap.release()\n            raise RuntimeError(f\"Could not open writer for: {out_path}\")\n        frames_in_current_chunk = 0\n        print(f\"[INFO] Writing: {out_path}\")\n\n    # Initialize writer for the first chunk\n    start_new_writer(chunk_idx)\n\n    try:\n        while True:\n            ok, frame = cap.read()\n            if not ok:\n                break  # end of video\n\n            writer.write(frame)\n            frames_in_current_chunk += 1\n            total_frames += 1\n\n            if frames_in_current_chunk >= chunk_num_frame:\n                writer.release()\n                chunk_idx += 1\n                start_new_writer(chunk_idx)\n    finally:\n        if writer is not None:\n            if frames_in_current_chunk == 0:\n                # last writer created but no frames written; try to delete empty file\n                writer.release()\n                empty_out = output_dir / f\"{stem}_chunk{chunk_idx:02d}.mp4\"\n                try:\n                    if empty_out.exists() and empty_out.stat().st_size == 0:\n                        empty_out.unlink(missing_ok=True)\n                except Exception:\n                    pass\n            else:\n                writer.release()\n        cap.release()\n\n    print(\"\\n[SUMMARY]\")\n    print(f\"  Input video: {input_path}\")\n    print(f\"  Output dir : {output_dir}\")\n    print(f\"  Total frames processed: {total_frames}\")\n    return output_dir\n","key":"bCNivDQ8vW"},{"type":"outputs","id":"i-97JLxuEuEHA3GVNSZTb","children":[],"key":"uHoGGSCtFF"}],"key":"YlBBGpdppa"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":2,"column":1},"end":{"line":2,"column":1}},"children":[{"type":"text","value":"3) Run the Splitter","position":{"start":{"line":2,"column":1},"end":{"line":2,"column":1}},"key":"gwcM99mJ2a"}],"identifier":"id-3-run-the-splitter","label":"3) Run the Splitter","html_id":"id-3-run-the-splitter","implicit":true,"key":"tcdQpnOw8N"},{"type":"paragraph","position":{"start":{"line":4,"column":1},"end":{"line":4,"column":1}},"children":[{"type":"text","value":"Run the cell below to split your video using the parameters defined earlier.","position":{"start":{"line":4,"column":1},"end":{"line":4,"column":1}},"key":"JyKI8qwYK2"}],"key":"qRnVzrCl3e"}],"key":"Vzn4fW4ulJ"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"\nout_dir = split_video_by_frames(input_path, chunk_num_frame, codec)\nout_dir\n","key":"iVwtqSqkSl"},{"type":"outputs","id":"nrbgAk3oLFkbs9m2wzFVK","children":[],"key":"vopioA2K8Q"}],"key":"QrzfZ0bR9a"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":2,"column":1},"end":{"line":2,"column":1}},"children":[{"type":"text","value":"4) Verify Outputs","position":{"start":{"line":2,"column":1},"end":{"line":2,"column":1}},"key":"NosnLPovYQ"}],"identifier":"id-4-verify-outputs","label":"4) Verify Outputs","html_id":"id-4-verify-outputs","implicit":true,"key":"JSqY6Vsyr9"},{"type":"paragraph","position":{"start":{"line":4,"column":1},"end":{"line":4,"column":1}},"children":[{"type":"text","value":"List the chunked files to confirm.","position":{"start":{"line":4,"column":1},"end":{"line":4,"column":1}},"key":"uifQSxVCG8"}],"key":"VG5t9DYHCg"}],"key":"B88lnPVCWR"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"\nsorted(list(out_dir.glob(\"*.mp4\")))\n","key":"nvv53T6Orf"},{"type":"outputs","id":"LAenoBqIHj0a1Hh4MRSq0","children":[],"key":"ZZo3RIXLB0"}],"key":"oEB3MhZFwH"}],"key":"VsgCClfw8X"},"references":{"cite":{"order":[],