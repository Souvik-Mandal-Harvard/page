eft_ear\",\"right_ear\",\n    \"left_shoulder\",\"right_shoulder\",\"left_elbow\",\"right_elbow\",\n    \"left_wrist\",\"right_wrist\",\"left_hip\",\"right_hip\",\n    \"left_knee\",\"right_knee\",\"left_ankle\",\"right_ankle\"\n]\nNUM_KP = len(COCO_KP_NAMES)\n","key":"OXwWNbMIKq"},{"type":"outputs","id":"lZ7bEB1mC-29M4A_qLGOV","children":[],"key":"OT8eRPRbzQ"}],"key":"ptcNcc1Dmq"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"7) Helper — Video Metadata","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"Lu1R3UJmL4"}],"identifier":"id-7-helper-video-metadata","label":"7) Helper — Video Metadata","html_id":"id-7-helper-video-metadata","implicit":true,"key":"pdK62ZHYZA"}],"key":"XUS8ufWTre"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"\n# DO NOT CHANGE ANYTHING IN THIS CELL\ndef get_video_fps_frames(path):\n    cap = cv2.VideoCapture(path)\n    if not cap.isOpened():\n        raise RuntimeError(f\"Cannot open video: {path}\")\n    fps = cap.get(cv2.CAP_PROP_FPS) or 30.0\n    frames = int(cap.get(cv2.CAP_PROP_FRAME_COUNT) or 0)\n    cap.release()\n    return fps, frames\n","key":"NZD2ivAPT6"},{"type":"outputs","id":"bR3WGDXwOsi6YlUkR3VVk","children":[],"key":"VQ94JP1ujh"}],"key":"RprSnwiEzG"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":2,"column":1},"end":{"line":2,"column":1}},"children":[{"type":"text","value":"8) Core Function — Track & Export Keypoints to CSV","position":{"start":{"line":2,"column":1},"end":{"line":2,"column":1}},"key":"dIVnJSM7Wd"}],"identifier":"id-8-core-function-track-export-keypoints-to-csv","label":"8) Core Function — Track & Export Keypoints to CSV","html_id":"id-8-core-function-track-export-keypoints-to-csv","implicit":true,"key":"YOlEuntkrb"},{"type":"list","ordered":false,"spread":false,"position":{"start":{"line":4,"column":1},"end":{"line":7,"column":1}},"children":[{"type":"listItem","spread":true,"position":{"start":{"line":4,"column":1},"end":{"line":4,"column":1}},"children":[{"type":"paragraph","children":[{"type":"text","value":"Uses ","position":{"start":{"line":4,"column":1},"end":{"line":4,"column":1}},"key":"rR0mujnlmS"},{"type":"strong","position":{"start":{"line":4,"column":1},"end":{"line":4,"column":1}},"children":[{"type":"text","value":"ByteTrack","position":{"start":{"line":4,"column":1},"end":{"line":4,"column":1}},"key":"AZTg7xVwms"}],"key":"TH8X1FbN8c"},{"type":"text","value":" for stable ","position":{"start":{"line":4,"column":1},"end":{"line":4,"column":1}},"key":"HD3WVWzYkn"},{"type":"inlineCode","value":"track_id","position":{"start":{"line":4,"column":1},"end":{"line":4,"column":1}},"key":"m9ccpB6CKw"},{"type":"text","value":".","position":{"start":{"line":4,"column":1},"end":{"line":4,"column":1}},"key":"NojqdNAPY9"}],"key":"NQCftGXxkA"}],"key":"bTqcCmJxvn"},{"type":"listItem","spread":true,"position":{"start":{"line":5,"column":1},"end":{"line":5,"column":1}},"children":[{"type":"paragraph","children":[{"type":"text","value":"Saves annotated video under ","position":{"start":{"line":5,"column":1},"end":{"line":5,"column":1}},"key":"J5SR3ffiSj"},{"type":"inlineCode","value":"OUTPUT_DIR/<run_name>/...","position":{"start":{"line":5,"column":1},"end":{"line":5,"column":1}},"key":"u1FccqtBlf"}],"key":"Q0Xc0MRrNZ"}],"key":"r3tEbxFjBH"},{"type":"listItem","spread":true,"position":{"start":{"line":6,"column":1},"end":{"line":6,"column":1}},"children":[{"type":"paragraph","children":[{"type":"text","value":"Saves CSV under ","position":{"start":{"line":6,"column":1},"end":{"line":6,"column":1}},"key":"QxdQRpMob3"},{"type":"inlineCode","value":"OUTPUT_DIR/<run_name>_keypoints.csv","position":{"start":{"line":6,"column":1},"end":{"line":6,"column":1}},"key":"cvs67cfxfM"}],"key":"w523fIvemH"}],"key":"UFKfijcjR2"},{"type":"listItem","spread":true,"position":{"start":{"line":7,"column":1},"end":{"line":7,"column":1}},"children":[{"type":"paragraph","children":[{"type":"text","value":"The pipeline supports ","position":{"start":{"line":7,"column":1},"end":{"line":7,"column":1}},"key":"Wptyr5KUFu"},{"type":"strong","position":{"start":{"line":7,"column":1},"end":{"line":7,"column":1}},"children":[{"type":"text","value":"Robust Export","position":{"start":{"line":7,"column":1},"end":{"line":7,"column":1}},"key":"lyMycuUMMv"}],"key":"LRZept1ZkF"},{"type":"text","value":" (handles missing/partial keypoints) - guarding against frames/people that return zero or partial keypoints by filling ","position":{"start":{"line":7,"column":1},"end":{"line":7,"column":1}},"key":"gJ9JEJgK1n"},{"type":"inlineCode","value":"None","position":{"start":{"line":7,"column":1},"end":{"line":7,"column":1}},"key":"cGb9nbqeNd"},{"type":"text","value":" values instead of indexing into an empty array.","position":{"start":{"line":7,"column":1},"end":{"line":7,"column":1}},"key":"jtt0WqwaDl"}],"key":"lHC4H6Divi"}],"key":"KRPDt0AbeA"}],"key":"j2JeOCfqg1"}],"key":"BQpSPQTlWn"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"\n# DO NOT CHANGE ANYTHING IN THIS CELL\ndef process_video_to_csv(\n    input_video: str,\n    output_dir: str,\n    model: YOLO,\n    conf: float = 0.25,\n    iou: float = 0.5,\n    imgsz: int = 640,\n    tracker: str = \"bytetrack.yaml\",\n    run_name: str = \"run1\",\n) -> dict:\n    \"\"\"Run YOLOv8-Pose tracking on a video and export keypoints to CSV.\n\n    Returns: {'csv_path', 'annotated_video_dir', 'annotated_video'}\n    \"\"\"\n    os.makedirs(output_dir, exist_ok=True)\n    fps, total_frames = get_video_fps_frames(input_video)\n    print(f\"Video FPS: {fps:.2f}, frames: {total_frames}\")\n\n    # Ensure ByteTrack dep is active (Ultralytics auto-installs lapx if needed; reruns handle it)\n    results = model.track(\n        source=input_video,\n        conf=conf,\n        iou=iou,\n        imgsz=imgsz,\n        device=0,\n        verbose=False,\n        stream=False,   # keep False for auto-saved annotated video\n        save=True,\n        project=output_dir,\n        name=run_name,\n        tracker=tracker,\n        persist=True\n    )\n\n    if not isinstance(results, list):\n        results = list(results)\n\n    rows = []\n    for frame_idx, r in enumerate(tqdm(results, desc=\"Extracting keypoints\")):\n        ts_ms = int(round(frame_idx * 1000.0 / max(fps, 1e-6)))\n\n        # Skip if no keypoints\n        if r.keypoints is None or r.keypoints.xy is None or len(r.keypoints.xy) == 0:\n            continue\n\n        kps_xy = r.keypoints.xy  # shape: [num_people, K, 2] (K may be 0 or < 17 sometimes)\n        kps_conf = getattr(r.keypoints, 'conf', None)\n        boxes = r.boxes\n\n        # Track IDs (optional; may be missing)\n        ids = None\n        if boxes is not None and getattr(boxes, 'id', None) is not None:\n            try:\n                ids = boxes.id.detach().cpu().numpy().astype(int)\n            except Exception:\n                ids = None\n\n        # Detection confidences\n        det_conf = None\n        if boxes is not None and getattr(boxes, 'conf', None) is not None:\n            try:\n                det_conf = boxes.conf.detach().cpu().numpy()\n            except Exception:\n                det_conf = None\n\n        num_people = kps_xy.shape[0]\n        for i in range(num_people):\n            # Pull per-person tensors/arrays\n            kpi = kps_xy[i]\n            if hasattr(kpi, 'detach'):\n                kpi = kpi.detach().cpu().numpy()  # shape: [K, 2]\n\n            kpci = None\n            if kps_conf is not None:\n                kpci = kps_conf[i]\n                if hasattr(kpci, 'detach'):\n                    kpci = kpci.detach().cpu().numpy()  # shape: [K]\n\n            K = kpi.shape[0] if kpi is not None and hasattr(kpi, 'shape') else 0\n\n            track_id = int(ids[i]) if ids is not None and i < len(ids) else -1\n            this_det_conf = float(det_conf[i]) if det_conf is not None and i < len(det_conf) else None\n\n            row = {\n                \"video_file\": os.path.basename(input_video),\n                \"frame_idx\": frame_idx,\n                \"timestamp_ms\": ts_ms,\n                \"track_id\": track_id,\n                \"det_conf\": this_det_conf\n            }\n\n            # Fill keypoints, guarding for K < 17 (or K == 0)\n            for kp_idx, kp_name in enumerate(COCO_KP_NAMES):\n                if K > kp_idx:\n                    x = float(kpi[kp_idx, 0])\n                    y = float(kpi[kp_idx, 1])\n                    row[f\"{kp_name}_x\"] = x\n                    row[f\"{kp_name}_y\"] = y\n                    if kpci is not None and kp_idx < len(kpci):\n                        row[f\"{kp_name}_conf\"] = float(kpci[kp_idx])\n                    else:\n                        row[f\"{kp_name}_conf\"] = None\n                else:\n                    row[f\"{kp_name}_x\"] = None\n                    row[f\"{kp_name}_y\"] = None\n                    row[f\"{kp_name}_conf\"] = None\n\n            rows.append(row)\n\n    df = pd.DataFrame(rows)\n    csv_path = os.path.join(output_dir, f\"{run_name}_keypoints.csv\")\n    df.to_csv(csv_path, index=False)\n    print(f\"Saved CSV: {csv_path}  ({len(df):,} rows)\")\n\n    ann_dir = os.path.join(output_dir, run_name)\n    ann_video = None\n    if os.path.isdir(ann_dir):\n        for f in os.listdir(ann_dir):\n            if f.lower().endswith((\".mp4\", \".avi\", \".mov\", \".mkv\")):\n                ann_video = os.path.join(ann_dir, f); break\n\n    return {\"csv_path\": csv_path, \"annotated_video_dir\": ann_dir if os.path.isdir(ann_dir) else None, \"annotated_video\": ann_video}\n","key":"Mg0B1i31ui"},{"type":"outputs","id":"7vYZm4RQMGHm4pUrX0ih9","children":[],"key":"GGkz9iJblk"}],"key":"kNYjUcCukA"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"9) Batch Run — Process Every Video in the Folder","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"SP2yCib799"}],"identifier":"id-9-batch-run-process-every-video-in-the-folder","label":"9) Batch Run — Process Every Video in the Folder","html_id":"id-9-batch-run-process-every-video-in-the-folder","implicit":true,"key":"KKd6kXksGw"},{"type":"list","ordered":false,"spread":false,"position":{"start":{"line":2,"column":1},"end":{"line":3,"column":1}},"children":[{"type":"listItem","spread":true,"position":{"start":{"line":2,"column":1},"end":{"line":2,"column":1}},"children":[{"type":"paragraph","children":[{"type":"text","value":"Uses the video filename (without extension) as ","position":{"start":{"line":2,"column":1},"end":{"line":2,"column":1}},"key":"y5Unrtny8H"},{"type":"inlineCode","value":"run_name","position":{"start":{"line":2,"column":1},"end":{"line":2,"column":1}},"key":"T4Z4sCuHRp"},{"type":"text","value":".","position":{"start":{"line":2,"column":1},"end":{"line":2,"column":1}},"key":"HYTo1zNNHU"}],"key":"xmjxhgekLP"}],"key":"uvvcXR6U9E"},{"type":"listItem","spread":true,"position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"children":[{"type":"paragraph","children":[{"type":"text","value":"Produces one CSV ","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"ipyvkm6pAX"},{"type":"emphasis","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"children":[{"type":"text","value":"and","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"GFWd8zukQb"}],"key":"S0Vzy4CBec"},{"type":"text","value":" an annotated video per input file.","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"vrcpsUpc37"}],"key":"G8lg5gqZfQ"}],"key":"KiiK8Qzh8s"}],"key":"Zt3BnDYxvQ"}],"key":"YZ10dm1QD4"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"\n# STUDENTS: You may change CONF/IOU/IMG_SIZE for experiments.\nCONF = 0.25   # min detection confidence (higher = fewer, more precise detections)\nIOU  = 0.5    # NMS overlap threshold (higher = fewer merges; lower = more aggressive suppression)\nIMG_SIZE = 640  # network input size (bigger = slower but potentially more accurate)\n\nall_outputs = []\nfor video_path in video_files:\n    run_name = os.path.splitext(os.path.basename(video_path))[0]\n    print(f\"\\n==============================\")\n    print(f\"🔍 Processing video: {video_path}\")\n    print(f\"Run name: {run_name}\")\n    print(\"==============================\\n\")\n\n    out = process_video_to_csv(\n        input_video=video_path,\n        output_dir=OUTPUT_DIR,\n        model=model,\n        conf=CONF,\n        iou=IOU,\n        imgsz=IMG_SIZE,\n        tracker=\"bytetrack.yaml\",\n        run_name=run_name\n    )\n    all_outputs.append(out)\n\nprint(\"\\n🎉 ALL VIDEOS COMPLETED!\")\nprint(\"Summary of outputs:\")\nfor o in all_outputs:\n    print(\" • CSV:\", o[\"csv_path\"], \"| Annotated video:\", o[\"annotated_video\"])\n","key":"Rj17YgPAM4"},{"type":"outputs","id":"zHyVBpSqwisXo91fJqbtN","children":[],"key":"bzijY18lp4"}],"key":"DzdPK5Tu77"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"10) Preview the First CSV","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"U9tkhonl6u"}],"identifier":"id-10-preview-the-first-csv","label":"10) Preview the First CSV","html_id":"id-10-preview-the-first-csv","implicit":true,"key":"viAk0awD3k"}],"key":"AOpESKF6z0"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"valu