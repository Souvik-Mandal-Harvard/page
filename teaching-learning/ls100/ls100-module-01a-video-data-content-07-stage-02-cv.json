\"left_elbow\",\"right_elbow\",\n    \"left_wrist\",\"right_wrist\",\"left_hip\",\"right_hip\",\n    \"left_knee\",\"right_knee\",\"left_ankle\",\"right_ankle\"\n]\nNUM_KP = len(COCO_KP_NAMES)\n","key":"olMd3Ks0gQ"},{"type":"outputs","id":"9y6K1P1eNcSULS-EhW85V","children":[],"key":"MoMNrmY026"}],"key":"Vk34AH6lek"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"7) Helper — Video Metadata","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"TgVC2rbBA6"}],"identifier":"id-7-helper-video-metadata","label":"7) Helper — Video Metadata","html_id":"id-7-helper-video-metadata","implicit":true,"key":"jhdM1NoQqe"}],"key":"cglTPRuhlP"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"\n# DO NOT CHANGE ANYTHING IN THIS CELL\ndef get_video_fps_frames(path):\n    cap = cv2.VideoCapture(path)\n    if not cap.isOpened():\n        raise RuntimeError(f\"Cannot open video: {path}\")\n    fps = cap.get(cv2.CAP_PROP_FPS) or 30.0\n    frames = int(cap.get(cv2.CAP_PROP_FRAME_COUNT) or 0)\n    cap.release()\n    return fps, frames\n","key":"R1sfElop0j"},{"type":"outputs","id":"3kAeJdBIXmy65qUFT_YST","children":[],"key":"wgA0pMIjNI"}],"key":"RrXvAikRxE"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":2,"column":1},"end":{"line":2,"column":1}},"children":[{"type":"text","value":"8) Core Function — Track & Export Keypoints to CSV","position":{"start":{"line":2,"column":1},"end":{"line":2,"column":1}},"key":"NzHVTCoNhl"}],"identifier":"id-8-core-function-track-export-keypoints-to-csv","label":"8) Core Function — Track & Export Keypoints to CSV","html_id":"id-8-core-function-track-export-keypoints-to-csv","implicit":true,"key":"VDGHZYSPIH"},{"type":"list","ordered":false,"spread":false,"position":{"start":{"