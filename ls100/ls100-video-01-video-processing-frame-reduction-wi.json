on":{"start":{"line":43,"column":1},"end":{"line":43,"column":1}},"children":[{"type":"text","value":"This preserves video timing.","position":{"start":{"line":43,"column":1},"end":{"line":43,"column":1}},"key":"X3K0urjODh"}],"key":"gbvpcD6F0n"},{"type":"thematicBreak","position":{"start":{"line":45,"column":1},"end":{"line":45,"column":1}},"key":"sSly8MdiV3"}],"key":"wI5TqBNz2k"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Make the Python Function","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"EFxEEUUx2a"}],"identifier":"make-the-python-function","label":"Make the Python Function","html_id":"make-the-python-function","implicit":true,"key":"mcy9eaPaS1"}],"key":"A6r1PpBCM9"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"import os\nimport cv2\nfrom tqdm import tqdm\n\ndef reduce_frames_in_directory(directory_path: str):\n    # Supported video extensions\n    VIDEO_EXTENSIONS = ('.mp4', '.mov', '.avi', '.mkv', '.flv')\n\n    # List all video files in the directory\n    files = [f for f in os.listdir(directory_path) if f.lower().endswith(VIDEO_EXTENSIONS)]\n\n    if not files:\n        print(\"No video files found in the directory.\")\n        return\n\n    for file in files:\n        input_path = os.path.join(directory_path, file)\n        basename, ext = os.path.splitext(file)\n\n        output_filename = f\"{basename}_FrameReduced{ext}\"\n        output_path = os.path.join(directory_path, output_filename)\n\n        print(f\"\\nProcessing: {file}\")\n        \n        cap = cv2.VideoCapture(input_path)\n        if not cap.isOpened():\n            print(f\"Could not open {file}. Skipping.\")\n            continue\n        \n        # Read input video properties\n        input_fps = cap.get(cv2.CAP_PROP_FPS)\n        width  = int(cap.get(cv2.CAP_PROP_FRAME_WIDTH))\n        height = int(cap.get(cv2.CAP_PROP_FRAME_HEIGHT))\n\n        # New FPS = half the original\n        output_fps = input_fps / 2\n\n        # Video writer\n        fourcc = cv2.VideoWriter_fourcc(*\"mp4v\")\n        out = cv2.VideoWriter(output_path, fourcc, output_fps, (width, height))\n\n        frame_count = int(cap.get(cv2.CAP_PROP_FRAME_COUNT))\n        \n        # Loop through frames\n        for i in tqdm(range(frame_count), desc=f\"Writing {output_filename}\"):\n            ret, frame = cap.read()\n            if not ret:\n                break\n            \n            # Skip every other frame → keep even-numbered frames only\n            if i % 2 == 0:\n                out.write(frame)\n\n        cap.release()\n        out.release()\n\n        print(f\"Saved: {output_filename}\")\n\n","key":"v8eY6cHEml"},{"type":"outputs","id":"2N9_ha3bZ80wNI_yWGG64","children":[],"key":"oOjl1B1HKt"}],"key":"BU5MHHxhDE"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"RUN THE FUNCTION BELOW","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"Z6naApca0p"}],"identifier":"run-the-function-below","label":"RUN THE FUNCTION BELOW","html_id":"run-the-function-below","implicit":true,"key":"Q9KDwN8SOo"}],"key":"VgOG59VItn"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"# Example:\ndirectory_path = \"path/to/yours/videos\"\nreduce_frames_in_directory(directory_path)","key":"mVaE7HT1TF"},{"type":"outputs","id":"Q4PiJpFVObRDxexbap5Q6","children":[],"key":"lc3hwT92A1"}],"key":"ZqCZ9Pa0BM"}],"key":"WmXHJqVgZt"},"references":{"cite":{"order":[],"data":{}}},"footer":{"navigation":{"prev":{"title":"Loading Data and Doing Useful Work — Video","url":"/ls100-video-00-getting-started","group":"Modules"},"next":{"title":"Video Chunker by Frame Count (OpenCV)","url":"/ls100-video-01-video-processing-video-chunker-by-f","group":"Modules"}}},"domain":"http://localhost:3000"}